  // Liquidité
  disponible    Boolean @default(true) // Liquidité immédiate
  preavisSortie Int? // Jours de préavis

  // Fiscalité
  regimeFiscal String? // IS, PFU, etc.

  notes     String? @db.Text
  documents Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@map("patrimoine_financier_pro")
}

// ============================================================================
// MODULE: REFERENCE DATA (Cache et Performance)
// ============================================================================

model ReferenceData {
  id String @id @default(cuid())

  domain  String // ACTIF_TYPE, PASSIF_TYPE, DOCUMENT_TYPE, etc.
  code    String // Code technique (ex: IMMOBILIER_RP)
  label   String // Label FR (ex: "Résidence principale")
