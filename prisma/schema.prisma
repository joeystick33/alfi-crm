enum CampaignStatus {
  BROUILLON
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
  PAUSE
}

enum CampaignType {
  EMAIL
  SMS
  POSTAL
  MULTI_CANAL
}

enum RecipientStatus {
  EN_ATTENTE
  ENVOYE
  DELIVRE
  OUVERT
  CLIQUE
  REBOND
  ERREUR
  DESABONNE
}

enum ScenarioTrigger {
  NOUVEAU_CLIENT
  ANNIVERSAIRE
  DATE_ECHEANCE
  ACTION_CLIENT
  INACTIVITE
  MANUEL
  WEBHOOK
}

enum ScenarioStatus {
  ACTIF
  INACTIF
  ARCHIVE
}

enum EmailMessageStatus {
  EN_ATTENTE
  ENVOYE
  DELIVRE
  OUVERT
  CLIQUE
  REBOND
  ERREUR
  ECHOUE
}

model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Identification
  name        String
  description String?        @db.Text
  type        CampaignType   @default(EMAIL)
  status      CampaignStatus @default(BROUILLON)

  // Créateur
  createdBy     String
  createdByUser User   @relation("CampaignCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  // Contenu
  subject      String? // Sujet email
  previewText  String? // Texte preview email
  htmlContent  String? @db.Text // Contenu HTML
  plainContent String? @db.Text // Contenu texte brut

  // Template associé (optionnel)
  emailTemplateId String?
  emailTemplate   EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)

  // Paramètres envoi
  scheduledAt DateTime? // Date envoi planifié
  sentAt      DateTime? // Date envoi réel
  completedAt DateTime? // Date fin envoi

  // Ciblage
  targetSegment    String?  @db.Text // Critères de ciblage JSON
  targetClientIds  String[] // IDs clients ciblés (si ciblage manuel)
  excludeClientIds String[] // IDs clients exclus

  // Statistiques
  recipientsTotal    Int @default(0)
  recipientsSent     Int @default(0)
  recipientsDelivré Int @default(0)
  recipientsOpened   Int @default(0)
  recipientsClicked  Int @default(0)
  recipientsBounced  Int @default(0)
  recipientsError    Int @default(0)

  // Taux calculés (%)
  openRate   Decimal? @db.Decimal(5, 2)
  clickRate  Decimal? @db.Decimal(5, 2)
  bounceRate Decimal? @db.Decimal(5, 2)

  // Configuration
  fromName  String?
  fromEmail String?
  replyTo   String?

  // Tracking
  trackOpens  Boolean @default(true)
  trackClicks Boolean @default(true)

  // Relations
  recipients CampaignRecipient[]
  messages   EmailMessage[]

  // Metadata
  tags  String[]
  notes String?  @db.Text

  // INDEX EXISTANTS ET COMPOSITES
  @@index([cabinetId, status])
  @@index([cabinetId, type])
  @@index([createdBy])
  @@index([scheduledAt])
  // NOUVEAUX INDEX
  @@index([cabinetId, status, scheduledAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Campaign
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Client
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Email destinataire
  email String

  // Statut
  status RecipientStatus @default(EN_ATTENTE)

  // Tracking
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  bouncedAt     DateTime?
  errorAt       DateTime?
  unsubscribeAt DateTime?

  // Compteurs
  openCount  Int @default(0)
  clickCount Int @default(0)

  // Erreur
  errorMessage String? @db.Text

  // Provider IDs (pour tracking avec provider externe)
  providerMessageId String? // ID message chez provider
  providerEventIds  String[] // IDs événements tracking

  @@unique([campaignId, clientId])
  @@index([campaignId, status])
  @@index([clientId])
  @@index([status])
  @@map("campaign_recipients")
}

model Scenario {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Identification
  name        String
  description String?        @db.Text
  status      ScenarioStatus @default(INACTIF)

  // Déclencheur
  trigger     ScenarioTrigger
  triggerData Json? // Configuration déclencheur (dates, conditions, etc.)

  // Template email associé
  emailTemplateId String?
  emailTemplate   EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)

  // Délai avant envoi (en heures)
  delayHours Int @default(0)

  // Conditions supplémentaires
  conditions Json? // Conditions JSON pour filtrage

  // Créateur
  createdBy     String
  createdByUser User   @relation("ScenarioCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  // Statistiques
  executionCount Int       @default(0) // Nombre fois exécuté
  lastExecutedAt DateTime?

  // Configuration
  fromName  String?
  fromEmail String?
  replyTo   String?

  // Relations
  messages EmailMessage[]

  // Metadata
  tags  String[]
  notes String?  @db.Text

  @@index([cabinetId, status])
  @@index([trigger])
  @@map("scenarios")
}

model EmailMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Destinataire
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  toEmail  String
  toName   String?

  // Expéditeur
  fromEmail String
  fromName  String?
  replyTo   String?

  // Contenu
  subject      String
  htmlContent  String  @db.Text
  plainContent String? @db.Text

  // Source
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  scenarioId String?
  scenario   Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  emailTemplateId String?
  emailTemplate   EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)

  // Statut
  status EmailMessageStatus @default(EN_ATTENTE)

  // Dates
  scheduledAt DateTime? // Date envoi planifié
  sentAt      DateTime? // Date envoi réel
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?
  errorAt     DateTime?

  // Tracking
  openCount  Int @default(0)
  clickCount Int @default(0)

  // Provider
  providerMessageId String? // ID chez provider email
  providerResponse  Json? // Réponse provider

  // Erreur
  errorMessage String? @db.Text

  // Metadata
  metadata Json? // Données supplémentaires

  // INDEX EXISTANTS
  @@index([cabinetId, status])
  @@index([clientId])
  @@index([campaignId])
  @@index([scenarioId])
  @@index([sentAt])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, clientId, status])
  @@index([scheduledAt, status])
  @@map("email_messages")
}

