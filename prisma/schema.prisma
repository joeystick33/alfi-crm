  @@unique([name])
  @@map("integrations")
}

// ============================================
// MODULE 10: Budget Détaillé (Revenus, Charges, Crédits)
// ============================================

enum RevenueCategory {
  // ============================================
  // Revenus du travail salarié
  // ============================================
  SALAIRE // Salaire - Rémunération contrat de travail
  PRIME // Prime - Primes exceptionnelles, intéressement, participation
  BONUS // Bonus - Bonus annuel, variable
  AVANTAGE_NATURE // Avantage en nature - Voiture, logement, téléphone
  INDEMNITE_LICENCIEMENT // Indemnité de licenciement
  INDEMNITE_RUPTURE_CONVENTIONNELLE // Indemnité rupture conventionnelle

  // ============================================
  // Revenus des indépendants (TNS)
  // ============================================
  BIC // Bénéfices Industriels et Commerciaux
  BNC // Bénéfices Non Commerciaux
  BA // Bénéfices Agricoles
  HONORAIRES // Honoraires - Professions libérales
  DROITS_AUTEUR // Droits d'auteur - Royalties, propriété intellectuelle

  // ============================================
  // Revenus de dirigeant
  // ============================================
  REMUNERATION_GERANT // Rémunération gérant - Gérant majoritaire ou minoritaire
  DIVIDENDES // Dividendes - Distribution de bénéfices
  JETONS_PRESENCE // Jetons de présence - Administrateur

  // ============================================
  // Revenus immobiliers
  // ============================================
