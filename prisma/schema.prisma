// Prisma Schema pour Aura CRM
// Base de données: PostgreSQL (Supabase)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// MODULE 1: Multi-Tenant et Utilisateurs
// ============================================

enum SuperAdminRole {
  OWNER
  ADMIN
  DEVELOPER
  SUPPORT
}

model SuperAdmin {
  id          String         @id @default(cuid())
  email       String         @unique
  password    String
  firstName   String
  lastName    String
  avatar      String?
  role        SuperAdminRole @default(ADMIN)
  permissions Json?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lastLogin   DateTime?

  auditLogs AuditLog[]

  // Relations SaaS
  sessions UserSession[]
  apiKeys  ApiKey[]
  webhooks WebhookEndpoint[]

  @@index([email])
  @@index([isActive])
  @@map("super_admins")
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  BUSINESS
  PREMIUM
}

enum CabinetStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  TERMINATED
  TRIALING
}

model Cabinet {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  email             String
  phone             String?
  address           Json?
  plan              SubscriptionPlan @default(TRIAL)
  status            CabinetStatus    @default(TRIALING)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  trialEndsAt       DateTime?
  quotas            Json?
  usage             Json?
  features          Json?
  restrictions      Json?

  // BYOK Integrations
  googleClientId        String?
  googleClientSecret    String?
  microsoftClientId     String?
  microsoftClientSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  users             User[]
  clients           Client[]
  actifs            Actif[]
  passifs           Passif[]
  contrats          Contrat[]
  documents         Document[]
  taches            Tache[]
  rendezvous        RendezVous[]
  objectifs         Objectif[]
  projets           Projet[]
  opportunites      Opportunite[]
  emails            Email[]
  notifications     Notification[]
  templates         Template[]
  apporteurs        ApporteurAffaires[]
  simulations       Simulation[]
  commercialActions CommercialAction[]
  auditLogs         AuditLog[]
  syncedEmails      SyncedEmail[]
  timelineEvents    TimelineEvent[]
  invoices          Invoice[]
  apporteursNew     Apporteur[]
  dossiers          Dossier[]
  campaigns         Campaign[]
  emailTemplates    EmailTemplate[]
  scenarios         Scenario[]
  emailMessages     EmailMessage[]
  kycDocuments      KYCDocument[]
  kycChecks         KYCCheck[]
  reclamations      Reclamation[]
  documentTemplates DocumentTemplate[]
  events            Event[]
  appointmentTypes  AppointmentType[]

  // Relations SaaS
  userSessions UserSession[]
  apiKeys      ApiKey[]
  webhooks     WebhookEndpoint[]
  saasInvoices SaaSInvoice[]

  // Relations Compliance Refonte
  complianceAlerts         ComplianceAlert[]
  complianceTimelineEvents ComplianceTimelineEvent[]

  // Relations Operations Refonte
  affairesNouvelles  AffaireNouvelle[]
  operationsGestion  OperationGestion[]
  operationProviders OperationProvider[]

  // Relations Documents Refonte
  regulatoryDocumentTemplates  RegulatoryDocumentTemplate[]
  regulatoryGeneratedDocuments RegulatoryGeneratedDocument[]

  // Relations Agent IA
  agentMemories      AgentMemory[]
  agentActions       AgentAction[]
  agentConversations AgentConversation[]
  aiChatThreads      AIChatThread[]

  // Relations AURA V2 — Agent Autonome
  aiConnections       AIConnection[]
  assistantProfiles   AssistantProfile[]
  aiSessions          AISession[]
  aiToolPermissions   AIToolPermission[]
  workflowStates      WorkflowState[]

  // Relations Entretiens
  entretiens Entretien[]

  // Relations RGPD
  dataProcessingRegistry DataProcessingRegistry[]

  @@index([slug])
  @@index([status])
  @@index([plan])
  @@map("cabinets")
}

enum UserRole {
  ADMIN
  ADVISOR
  ASSISTANT
}

model User {
  id            String    @id @default(cuid())
  cabinetId     String
  cabinet       Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  email         String    @unique
  emailVerified DateTime?
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          UserRole  @default(ADVISOR)
  permissions   Json?
  stats         Json?
  preferences   Json?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?

  clientsPrincipaux        Client[]              @relation("ConseillerPrincipal")
  clientsRemplacants       Client[]              @relation("ConseillerRemplacant")
  assistantAssignments     AssistantAssignment[]
  taches                   Tache[]
  tachesCreated            Tache[]               @relation("TacheCreatedBy")
  rendezvous               RendezVous[]          @relation("ConseillerRendezVous")
  rendezVousRescheduled    RendezVous[]          @relation("RescheduledBy")
  opportunites             Opportunite[]
  emails                   Email[]
  documents                Document[]            @relation("UploadedBy")
  apporteurs               ApporteurAffaires[]
  simulations              Simulation[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  calendarSyncs            CalendarSync[]
  syncedEmails             SyncedEmail[]
  emailIntegration         EmailIntegration?
  invoices                 Invoice[]             @relation("ConseillerInvoices")
  dossiers                 Dossier[]             @relation("ConseillerDossiers")
  campaignsCreated         Campaign[]            @relation("CampaignCreator")
  emailTemplatesCreated    EmailTemplate[]       @relation("TemplateCreator")
  scenariosCreated         Scenario[]            @relation("ScenarioCreator")
  kycDocumentsValidated    KYCDocument[]         @relation("KYCDocumentValidator")
  kycChecksAssigned        KYCCheck[]            @relation("KYCCheckAssignee")
  kycChecksCompleted       KYCCheck[]            @relation("KYCCheckCompleter")
  reclamationsAssigned     Reclamation[]         @relation("ReclamationAssignee")
  slaEvents                SLAEvent[]            @relation("SLAEventUser")
  documentTemplatesCreated DocumentTemplate[]    @relation("TemplateCreator")

  // Relations SaaS
  sessions UserSession[]
  events   Event[]

  // Relations Calendrier/RDV
  appointmentTypes AppointmentType[]
  availabilities   Availability[]
  blockedSlots     BlockedSlot[]

  // Relations Compliance Refonte
  alertsAcknowledged       ComplianceAlert[]         @relation("AlertAcknowledger")
  complianceTimelineEvents ComplianceTimelineEvent[] @relation("ComplianceTimelineUser")

  // Relations Operations Refonte
  affairesCreated        AffaireNouvelle[]        @relation("AffaireCreator")
  affaireStatusHistory   AffaireStatusHistory[]   @relation("AffaireStatusHistoryUser")
  operationsCreated      OperationGestion[]       @relation("OperationCreator")
  operationStatusHistory OperationStatusHistory[] @relation("OperationStatusHistoryUser")

  // Relations Documents Refonte
  regulatoryTemplatesCreated   RegulatoryDocumentTemplate[]  @relation("RegulatoryTemplateCreator")
  regulatoryDocumentsGenerated RegulatoryGeneratedDocument[] @relation("RegulatoryDocumentGenerator")

  // Relations Agent IA
  agentMemories      AgentMemory[]        @relation("AgentMemories")
  agentActions       AgentAction[]        @relation("AgentActions")
  agentConversations AgentConversation[]  @relation("AgentConversations")
  aiChatThreads      AIChatThread[]       @relation("AIChatThreads")

  // Relations AURA V2 — Agent Autonome
  aiSessions         AISession[]          @relation("AISessionsUser")

  // Relations Entretiens
  entretiens Entretien[] @relation("ConseillerEntretiens")

  @@index([cabinetId])
  @@index([cabinetId, role])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model AssistantAssignment {
  id          String   @id @default(cuid())
  cabinetId   String
  assistantId String
  advisorId   String
  assistant   User     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([assistantId, advisorId])
  @@index([cabinetId])
  @@index([assistantId])
  @@index([advisorId])
  @@map("assistant_assignments")
}

enum ApporteurType {
  NOTAIRE
  EXPERT_COMPTABLE
  BANQUIER
  COURTIER
  AUTRE
}

model ApporteurAffaires {
  id             String        @id @default(cuid())
  cabinetId      String
  cabinet        Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  ownerId        String?
  owner          User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  type           ApporteurType
  firstName      String
  lastName       String
  email          String
  phone          String?
  company        String?
  profession     String?
  commissionRate Decimal?      @db.Decimal(5, 2)
  stats          Json?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  clients Client[]

  @@index([cabinetId])
  @@index([ownerId])
  @@index([type])
  @@map("apporteurs_affaires")
}

// ============================================
// MODULE 2: Gestion des Clients
// ============================================

enum MaritalStatus {
  CELIBATAIRE // Célibataire
  MARIE // Marié(e)
  DIVORCE // Divorcé(e)
  VEUF // Veuf/Veuve
  PACSE // Pacsé(e)
  CONCUBINAGE // Concubinage
}

enum RiskProfile {
  CONSERVATEUR // Conservateur - Sécurité maximale
  PRUDENT // Prudent - Risque faible
  EQUILIBRE // Équilibré - Risque modéré
  DYNAMIQUE // Dynamique - Risque élevé
  OFFENSIF // Offensif - Risque maximum
}

enum InvestmentHorizon {
  COURT // Court terme (<3 ans)
  MOYEN // Moyen terme (3-8 ans)
  LONG // Long terme (>8 ans)
}

enum KYCStatus {
  EN_ATTENTE // En attente
  EN_COURS // En cours
  COMPLET // Complet
  EXPIRE // Expiré
  REJETE // Rejeté
}

enum ClientStatus {
  PROSPECT // Prospect
  ACTIF // Client actif
  INACTIF // Client inactif
  ARCHIVE // Archivé
  PERDU // Perdu
}

enum ClientType {
  PARTICULIER
  PROFESSIONNEL
}

model Client {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Type de client (Particulier ou Professionnel)
  clientType             ClientType         @default(PARTICULIER)
  conseillerId           String
  conseiller             User               @relation("ConseillerPrincipal", fields: [conseillerId], references: [id])
  conseillerRemplacantId String?
  conseillerRemplacant   User?              @relation("ConseillerRemplacant", fields: [conseillerRemplacantId], references: [id])
  apporteurId            String?
  apporteur              ApporteurAffaires? @relation(fields: [apporteurId], references: [id], onDelete: SetNull)

  email       String?
  firstName   String
  lastName    String
  birthDate   DateTime?
  birthPlace  String?
  nationality String?
  phone       String?
  mobile      String?
  address     Json?

  maritalStatus    MaritalStatus?
  marriageRegime   String?
  numberOfChildren Int?           @default(0)

  profession         String?
  employerName       String?
  professionalStatus String?

  // Informations spécifiques pour clients PROFESSIONNELS
  companyName         String? // Nom de l'entreprise
  siret               String? // SIRET
  legalForm           String? // SARL, SAS, SA, etc.
  activitySector      String? // Secteur d'activité
  companyCreationDate DateTime? // Date de création
  numberOfEmployees   Int? // Nombre de salariés
  annualRevenue       Decimal?  @db.Decimal(15, 2) // CA annuel

  annualIncome    Decimal? @db.Decimal(12, 2)
  taxBracket      String?
  fiscalResidence String?

  // Fiscalité détaillée
  irTaxRate        Decimal? @db.Decimal(5, 2) // Taux marginal IR (%)
  ifiSubject       Boolean  @default(false) // Soumis à l'IFI
  ifiAmount        Decimal? @db.Decimal(15, 2) // Montant IFI payé
  taxOptimizations Json? // Défiscalisations effectuées (Pinel, Malraux, etc.)
  fiscalNotes      String?  @db.Text // Notes fiscales

  // Profil investisseur (MiFID II)
  riskProfile          RiskProfile?
  investmentHorizon    InvestmentHorizon?
  investmentGoals      Json?
  investmentKnowledge  String? // Niveau de connaissance financière
  investmentExperience String? // Expérience en investissement

  // Patrimoine (calculé automatiquement)
  wealth Json? // { totalAssets, totalLiabilities, netWealth, managedAssets, unmanagedAssets, lastCalculated }

  // Gestion du patrimoine
  managedByFirm       Boolean   @default(false) // Patrimoine géré par le cabinet
  managementStartDate DateTime? // Date de début de gestion
  managementFees      Decimal?  @db.Decimal(5, 2) // Frais de gestion (%)
  managementType      String? // Type de mandat (conseil, gestion pilotée, etc.)

  kycStatus         KYCStatus @default(EN_ATTENTE)
  kycCompletedAt    DateTime?
  kycNextReviewDate DateTime?

  // Champs KYC/LCB-FT obligatoires
  isPEP         Boolean @default(false) // Personne Politiquement Exposée
  originOfFunds String? // Origine des fonds (salaire, héritage, vente immobilière, etc.)

  status ClientStatus @default(PROSPECT)

  portalAccess    Boolean   @default(false)
  portalPassword  String?
  lastPortalLogin DateTime?

  // === CHAMPS ENRICHIS POUR FORMULAIRE 7 ÉTAPES ===

  // Civilité (pour formulaire enrichi)
  civilite String? // M, MME, MLLE

  // Nom d'usage (nom marital)
  nomUsage String?

  // Résidence fiscale (pays) - Code pays ISO
  taxResidenceCountry String? // FR, BE, CH, etc.

  // Régime matrimonial
  matrimonialRegime String? // SEPARATION, COMMUNAUTE, UNIVERSELLE, PARTICIPATION

  // Personnes à charge (autres que enfants)
  dependents Int? @default(0)

  // Catégorie socio-professionnelle
  professionCategory String? // CADRE_SUP, CADRE, PROFESS_LIB, CHEF_ENTR, EMPLOYE, OUVRIER, AGRICULTEUR, ARTISAN, COMMERCANT, RETRAITE, ETUDIANT, SANS_EMPLOI, AUTRE

  // Type de contrat
  employmentType String? // CDI, CDD, INDEPENDANT, INTERIM, STAGE, ALTERNANCE, FREELANCE

  // Date d'embauche / début activité
  employmentSince DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastContactDate DateTime?

  familyMembers      FamilyMember[]
  actifs             ClientActif[]
  passifs            Passif[]
  contrats           Contrat[]
  objectifs          Objectif[]
  projets            Projet[]
  opportunites       Opportunite[]
  taches             Tache[]
  rendezvous         RendezVous[]
  documents          ClientDocument[]
  emails             Email[]
  notifications      Notification[]
  simulations        Simulation[]
  kycDocuments       KYCDocument[]
  kycChecks          KYCCheck[]
  consentements      Consentement[]
  reclamations       Reclamation[]
  timelineEvents     TimelineEvent[]
  syncedEmails       SyncedEmail[]
  invoices           Invoice[]
  commissions        Commission[]
  apporteurNew       Apporteur?          @relation("ApporteurClients", fields: [apporteurNewId], references: [id], onDelete: SetNull)
  apporteurNewId     String?
  dossiers           Dossier[]
  campaignRecipients CampaignRecipient[]
  emailMessages      EmailMessage[]
  events             Event[]

  // === NOUVELLES RELATIONS BUDGET & FISCALITÉ ===
  budget              ClientBudget?
  taxation            ClientTaxation?
  fiscalOptimizations TaxOptimization[]
  settings            ClientSettings?

  // === RELATIONS BUDGET DÉTAILLÉ & BIENS MOBILIERS ===
  revenues       Revenue[]
  expenses       Expense[]
  credits        Credit[]
  biensMobiliers BienMobilier[]

  // === RELATIONS CLIENT360 PRO ===
  interlocuteurs         Interlocuteur[]
  epargneSalariale       EpargneSalariale[]
  protectionSocialePro   ProtectionSocialePro[]
  financementsPro        FinancementPro[]
  immobilierPro          ImmobilierPro[]
  patrimoineFinancierPro PatrimoineFinancierPro[]

  // === SNAPSHOTS PATRIMOINE ===
  patrimoineSnapshots PatrimoineSnapshot[]

  // === RELATIONS COMPLIANCE REFONTE ===
  complianceAlerts         ComplianceAlert[]
  complianceTimelineEvents ComplianceTimelineEvent[]

  // === RELATIONS OPERATIONS REFONTE ===
  affairesNouvelles AffaireNouvelle[]
  operationsGestion OperationGestion[]

  // === RELATIONS DOCUMENTS REFONTE ===
  regulatoryGeneratedDocuments RegulatoryGeneratedDocument[]

  // === RELATIONS AGENT IA ===
  agentMemories      AgentMemory[]
  agentActions       AgentAction[]
  agentConversations AgentConversation[]
  aiChatThreads      AIChatThread[]

  // === RELATIONS AURA V2 — Agent Autonome ===
  aiSessions         AISession[]

  // === RELATIONS ENTRETIENS ===
  entretiens Entretien[]

  // === RELATIONS CONFORMITÉ AVANCÉE ===
  mifidQuestionnaires    MiFIDQuestionnaire[]
  lcbftRiskAssessments   LCBFTRiskAssessment[]
  marketingConsents      MarketingConsent[]

  // === CHAMPS DÉNORMALISÉS POUR PERFORMANCE ===
  // Ces champs sont mis à jour par PatrimoineSnapshot
  totalActifs     Decimal?  @db.Decimal(15, 2)
  totalPassifs    Decimal?  @db.Decimal(15, 2)
  patrimoineNet   Decimal?  @db.Decimal(15, 2)
  totalRevenus    Decimal?  @db.Decimal(12, 2)
  totalCharges    Decimal?  @db.Decimal(12, 2)
  capaciteEpargne Decimal?  @db.Decimal(12, 2)
  tauxEndettement Decimal?  @db.Decimal(5, 2)
  lastSnapshotAt  DateTime?

  // CONTRAINTE UNIQUE
  @@unique([cabinetId, email])
  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([conseillerId])
  @@index([status])
  @@index([clientType])
  @@index([kycStatus])
  @@index([email])
  // NOUVEAUX INDEX COMPOSITES POUR PERFORMANCE
  @@index([cabinetId, conseillerId, status])
  @@index([cabinetId, status, lastContactDate])
  @@index([cabinetId, kycStatus, kycNextReviewDate])
  @@index([cabinetId, clientType, status])
  @@index([cabinetId, patrimoineNet])
  @@map("clients")
}

enum FamilyRelationship {
  CONJOINT // Époux/Épouse, Partenaire PACS
  ENFANT // Enfant
  PARENT // Père/Mère
  FRATRIE // Frère/Sœur
  PETIT_ENFANT // Petit-enfant
  AUTRE // Autre lien
  ASCENDANT // Grand-parent, arrière-grand-parent
}

model FamilyMember {
  id             String             @id @default(cuid())
  clientId       String
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  birthDate      DateTime?
  relationship   FamilyRelationship
  linkedClientId String?
  isBeneficiary  Boolean            @default(false)

  // === CHAMPS ENRICHIS POUR FORMULAIRE 7 ÉTAPES ===
  civility     String? // M, MME, MLLE
  profession   String?
  annualIncome Decimal? @db.Decimal(10, 2)
  isDependent  Boolean  @default(false) // À charge fiscalement
  email        String?
  phone        String?
  notes        String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("family_members")
}

// ============================================
// MODULE 2.5: Budget & Fiscalité Client
// ============================================

model ClientBudget {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // === REVENUS (JSON) ===
  // Structure: { netSalary: number, selfEmployedIncome: number, bonuses: number, other: number }
  professionalIncome Json?

  // Structure: { rentalIncome: number, dividends: number, interest: number, capitalGains: number }
  assetIncome Json?

  // Structure: { netSalary: number, other: number }
  spouseIncome Json?

  // Structure: { total: number }
  retirementPensions Json?

  // Structure: { total: number }
  allowances Json?

  // === CHARGES (JSON) ===
  // Structure: { housing: { total: number }, utilities: { total: number }, food: { total: number }, 
  //             transportation: { total: number }, insurance: { total: number }, leisure: { total: number },
  //             health: { total: number }, education: { total: number }, loans: { total: number }, other: { total: number } }
  monthlyExpenses Json?

  // === MÉTRIQUES CALCULÉES ===
  // Ces champs sont mis à jour automatiquement par le service budget
  totalRevenue    Decimal? @db.Decimal(12, 2)
  totalExpenses   Decimal? @db.Decimal(12, 2)
  savingsCapacity Decimal? @db.Decimal(12, 2)
  savingsRate     Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_budgets")
}

model ClientTaxation {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Année fiscale de référence
  anneeFiscale Int @default(2024)

  // === IMPÔT SUR LE REVENU (JSON) ===
  // Structure: { 
  //   fiscalReferenceIncome: number,  // Revenu fiscal de référence
  //   taxShares: number,               // Nombre de parts
  //   quotientFamilial: number,        // RFR / parts (calculé)
  //   taxBracket: number,              // TMI: 0, 11, 30, 41, 45
  //   annualAmount: number,            // Montant IR annuel
  //   monthlyPayment: number,          // Prélèvement mensuel
  //   taxCredits: number,              // Crédits d'impôt
  //   taxReductions: number            // Réductions d'impôt
  // }
  incomeTax Json?

  // === IFI (JSON) ===
  // Structure: { 
  //   taxableRealEstateAssets: number,  // Patrimoine immobilier brut
  //   deductibleLiabilities: number,    // Dettes déductibles
  //   netTaxableIFI: number,            // Patrimoine net taxable
  //   ifiAmount: number,                // Montant IFI estimé
  //   bracket: string,                  // Tranche IFI
  //   threshold: 1300000                // Seuil d'assujettissement
  // }
  ifi Json?

  // === PRÉLÈVEMENTS SOCIAUX (JSON) ===
  // Structure: { 
  //   taxableAssetIncome: number,  // Revenus du patrimoine soumis
  //   rate: 0.172,                 // 17.2%
  //   amount: number               // Montant PS
  // }
  socialContributions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_taxation")
}

// ============================================
// MODULE 2.6: Client Settings (Client 360)
// ============================================

model ClientSettings {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // === PREFERENCES ===
  communication      String @default("EMAIL") // EMAIL, PHONE, BOTH
  reportingFrequency String @default("QUARTERLY") // MONTHLY, QUARTERLY, ANNUAL
  language           String @default("fr")

  // === FISCAL PARAMETERS ===
  taxYear        Int?
  selectedRegime String? // Régime fiscal sélectionné

  // === BANK ACCOUNTS (JSON) ===
  // Structure: [{ id, bankName, accountType, iban, isMain }]
  bankAccounts Json?

  // === ACCESS RIGHTS (JSON) ===
  // Structure: [{ advisorId, advisorName, role, permissions }]
  accessRights Json?

  // === NOTIFICATIONS (JSON) ===
  // Structure: [{ type, enabled, channels }]
  notifications Json?

  // === PRIVACY ===
  dataConsent      Boolean   @default(false)
  marketingConsent Boolean   @default(false)
  consentDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_settings")
}

enum TaxOptimizationPriority {
  BASSE // Basse
  MOYENNE // Moyenne
  HAUTE // Haute
  URGENTE // Urgente
}

enum TaxOptimizationStatus {
  DETECTEE // Détectée automatiquement
  EN_COURS // En cours de mise en place
  APPLIQUEE // Appliquée/Réalisée
  REJETEE // Rejetée/Écartée
  EXPIREE // Expirée
}

model TaxOptimization {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  priority         TaxOptimizationPriority @default(MOYENNE)
  category         String // TAX, SAVINGS, INVESTMENT, RETIREMENT, REAL_ESTATE, etc.
  title            String // Ex: "PER pour réduction IR"
  description      String                  @db.Text
  potentialSavings Decimal?                @db.Decimal(10, 2) // Économie potentielle en €
  recommendation   String                  @db.Text
  status           TaxOptimizationStatus   @default(DETECTEE)

  // Dates de suivi
  reviewedAt    DateTime?
  reviewedBy    String? // User ID
  completedAt   DateTime?
  dismissedAt   DateTime?
  dismissReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, status])
  @@index([priority])
  @@index([status])
  @@map("tax_optimizations")
}

// ============================================
// MODULE 3: Gestion du Patrimoine
// ============================================

enum ActifType {
  // === IMMOBILIER ===
  RESIDENCE_PRINCIPALE // Résidence principale
  IMMOBILIER_LOCATIF // Immobilier locatif
  RESIDENCE_SECONDAIRE // Résidence secondaire
  IMMOBILIER_COMMERCIAL // Immobilier commercial
  SCPI // SCPI
  SCI // SCI
  OPCI // OPCI
  CROWDFUNDING_IMMO // Crowdfunding immobilier
  VIAGER // Viager
  NUE_PROPRIETE // Nue-propriété
  USUFRUIT // Usufruit

  // === ÉPARGNE SALARIALE ===
  PEE // Plan Épargne Entreprise
  PEG // Plan Épargne Groupe
  PERCO // PERCO (ancien)
  PERECO // PER Collectif (nouveau)
  CET // Compte Épargne Temps
  PARTICIPATION // Participation
  INTERESSEMENT // Intéressement
  STOCK_OPTIONS // Stock-options
  ACTIONS_GRATUITES // Actions gratuites
  BSPCE // BSPCE

  // === ÉPARGNE RETRAITE ===
  PER // PER individuel
  PERP // PERP (ancien)
  MADELIN // Contrat Madelin
  ARTICLE_83 // Article 83
  PREFON // PREFON
  COREM // COREM

  // === PLACEMENTS FINANCIERS ===
  ASSURANCE_VIE // Assurance-vie
  CONTRAT_CAPITALISATION // Contrat de capitalisation
  COMPTE_TITRES // Compte-titres ordinaire
  PEA // PEA
  PEA_PME // PEA-PME

  // === ÉPARGNE BANCAIRE ===
  COMPTE_BANCAIRE // Compte courant
  LIVRETS // Livrets (A, LDDS, LEP)
  PEL // PEL
  CEL // CEL
  COMPTE_A_TERME // Compte à terme

  // === ACTIFS PROFESSIONNELS ===
  PARTS_SOCIALES // Parts sociales / actions entreprise
  IMMOBILIER_PRO // Immobilier professionnel
  MATERIEL_PRO // Matériel professionnel
  FONDS_COMMERCE // Fonds de commerce
  BREVETS_PI // Brevets et PI

  // === MOBILIER & DIVERS ===
  METAUX_PRECIEUX // Or / Métaux précieux
  BIJOUX // Bijoux
  OEUVRES_ART // Œuvres d'art / Tableaux
  VINS // Vins & spiritueux
  MONTRES // Montres de collection
  VEHICULES // Véhicules (voiture, moto, bateau)
  MOBILIER // Mobilier de valeur
  CRYPTO // Cryptomonnaies
  NFT // NFT / Actifs numériques

  AUTRE // Autre
}

enum ActifCategory {
  IMMOBILIER
  FINANCIER
  EPARGNE_SALARIALE
  EPARGNE_RETRAITE
  PROFESSIONNEL
  MOBILIER
  AUTRE
}

model Actif {
  id               String        @id @default(cuid())
  cabinetId        String
  cabinet          Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  type             ActifType
  category         ActifCategory
  name             String
  description      String?
  value            Decimal       @db.Decimal(15, 2)
  acquisitionDate  DateTime?
  acquisitionValue Decimal?      @db.Decimal(15, 2)
  details          Json? // Champs spécifiques selon type (voir patrimoine-config.ts)
  annualIncome     Decimal?      @db.Decimal(12, 2)
  taxDetails       Json?

  // Gestion par le cabinet
  managedByFirm  Boolean  @default(false)
  managementFees Decimal? @db.Decimal(5, 2)

  // === DONNÉES COMMUNES ===
  location          String? // Localisation (ville, pays)
  managementAdvisor String? // Conseiller référent
  managementSince   DateTime? // Date début gestion
  currency          String    @default("EUR") // Devise

  // === IMMOBILIER ===
  // Adresse et caractéristiques
  propertyAddress       String? // Adresse complète
  propertyCity          String? // Ville
  propertyPostalCode    String? // Code postal
  propertySurface       Decimal? @db.Decimal(10, 2) // Surface m²
  propertyRooms         Int? // Nombre de pièces
  propertyType          String? // Appartement, Maison, Terrain, etc.
  propertyCondition     String? // Neuf, Ancien, VEFA
  propertyParkingSpaces Int? // Places de parking

  // Dispositif fiscal locatif
  rentalScheme          String? // NUE (nu), LMNP, LMP, DEFICIT_FONCIER, PINEL, DENORMANDIE, MALRAUX, MONUMENT_HISTORIQUE, COSSE, LOI_DEMESSINE
  rentalSchemeStartDate DateTime? // Date début dispositif
  rentalSchemeEndDate   DateTime? // Date fin engagement
  rentalMonthlyRent     Decimal?  @db.Decimal(12, 2) // Loyer mensuel
  rentalCharges         Decimal?  @db.Decimal(12, 2) // Charges locatives
  rentalOccupancyRate   Decimal?  @db.Decimal(5, 2) // Taux d'occupation %
  rentalTenantName      String? // Nom du locataire actuel
  rentalLeaseEndDate    DateTime? // Fin du bail

  // Données IFI
  fiscalPropertyType   String? // RP, SECONDARY, RENTAL, COMMERCIAL
  fiscalRpAbatement    Boolean  @default(false) // Abattement 30% RP
  fiscalManualDiscount Decimal? @db.Decimal(5, 2) // Décote manuelle %
  fiscalIfiValue       Decimal? @db.Decimal(15, 2) // Valeur IFI calculée

  // Démembrement
  dismembermentType    String? // PLEINE_PROPRIETE, NUE_PROPRIETE, USUFRUIT
  dismembermentEndDate DateTime? // Fin du démembrement
  usufructuaryName     String? // Nom de l'usufruitier
  bareOwnerName        String? // Nom du nu-propriétaire

  // === ASSURANCE-VIE / CONTRAT DE CAPITALISATION ===
  insurerName           String? // Nom de l'assureur
  contractNumber        String? // Numéro de contrat
  contractOpenDate      DateTime? // Date d'ouverture (antériorité fiscale)
  beneficiaryClause     String?   @db.Text // Clause bénéficiaire complète
  beneficiaryClauseType String? // STANDARD, DEMEMBREE, PERSONNALISEE
  beneficiaries         Json? // [{name, percentage, rank, relationship}]
  totalPremiums         Decimal?  @db.Decimal(15, 2) // Total versements
  premiumsBefore70      Decimal?  @db.Decimal(15, 2) // Versements avant 70 ans
  premiumsAfter70       Decimal?  @db.Decimal(15, 2) // Versements après 70 ans
  surrenderValue        Decimal?  @db.Decimal(15, 2) // Valeur de rachat
  unrealizedGains       Decimal?  @db.Decimal(15, 2) // Plus-value latente
  fundsAllocation       Json? // [{fundName, isin, percentage, value, type: 'EURO'|'UC'}]
  euroFundRate          Decimal?  @db.Decimal(5, 2) // Taux fonds euros
  managementMode        String? // LIBRE, GESTION_PILOTEE, GESTION_SOUS_MANDAT

  // === PEA / COMPTE-TITRES ===
  brokerName        String? // Nom du courtier/banque
  accountNumber     String? // Numéro de compte
  portfolioLines    Json? // [{isin, name, quantity, buyPrice, currentPrice, sector}]
  dividendsReceived Decimal? @db.Decimal(12, 2) // Dividendes reçus année

  // === ÉPARGNE SALARIALE ===
  employerName     String? // Nom de l'employeur
  vestingSchedule  Json? // Calendrier d'acquisition
  availabilityDate DateTime? // Date de disponibilité
  unvestedAmount   Decimal?  @db.Decimal(15, 2) // Montant non acquis

  // === MOBILIER / OBJETS DE VALEUR ===
  objectBrand          String? // Marque (Rolex, Cartier, etc.)
  objectModel          String? // Modèle
  objectSerial         String? // Numéro de série
  objectCertificate    Boolean   @default(false) // Certificat authenticité
  objectInsured        Boolean   @default(false) // Assuré
  objectInsuranceValue Decimal?  @db.Decimal(15, 2) // Valeur assurée
  lastAppraisalDate    DateTime? // Dernière expertise
  lastAppraisalValue   Decimal?  @db.Decimal(15, 2) // Valeur expertise

  // === VÉHICULES ===
  vehicleBrand        String? // Marque
  vehicleModel        String? // Modèle
  vehicleYear         Int? // Année
  vehicleRegistration String? // Immatriculation
  vehicleMileage      Int? // Kilométrage

  // === CRYPTO / NFT ===
  walletAddress    String? // Adresse du wallet
  exchangePlatform String? // Plateforme (Binance, Coinbase, etc.)
  tokenSymbol      String? // Symbole (BTC, ETH, etc.)
  tokenQuantity    Decimal? @db.Decimal(20, 8) // Quantité

  // === PROFESSIONNEL ===
  companyName        String? // Nom de l'entreprise
  companySiren       String? // SIREN
  companyLegalForm   String? // Forme juridique
  companySharesCount Int? // Nombre de parts/actions
  companyTotalShares Int? // Total parts/actions

  // Linkage actif ↔ passif
  linkedPassifId String? // ID du passif associé (crédit)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients   ClientActif[]
  documents ActifDocument[]
  passifs   Passif[] // Passifs liés à cet actif

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([type])
  @@index([category])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, category, isActive])
  @@index([cabinetId, managedByFirm, isActive])
  @@index([cabinetId, type, isActive])
  @@map("actifs")
}

model ClientActif {
  id                  String   @id @default(cuid())
  clientId            String
  actifId             String
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  actif               Actif    @relation(fields: [actifId], references: [id], onDelete: Cascade)
  ownershipPercentage Decimal  @default(100.00) @db.Decimal(5, 2)
  ownershipType       String?
  createdAt           DateTime @default(now())

  @@unique([clientId, actifId])
  @@index([clientId])
  @@index([actifId])
  @@map("client_actifs")
}

enum PassifType {
  CREDIT_IMMOBILIER // Crédit immobilier
  PTZ // Prêt à taux zéro
  PRET_ACTION_LOGEMENT // Prêt Action Logement
  CREDIT_CONSOMMATION // Crédit consommation
  CREDIT_AUTO // Crédit auto
  PRET_ETUDIANT // Prêt étudiant
  PRET_PROFESSIONNEL // Prêt professionnel
  CREDIT_REVOLVING // Crédit revolving
  PRET_RELAIS // Prêt relais
  PRET_IN_FINE // Prêt in fine
  PRET_FAMILIAL // Prêt familial
  DECOUVERT // Découvert bancaire
  LEASING // Leasing / LOA
  AUTRE // Autre
}

model Passif {
  id          String     @id @default(cuid())
  cabinetId   String
  cabinet     Cabinet    @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        PassifType
  name        String
  description String?

  // === MONTANTS ===
  initialAmount   Decimal @db.Decimal(15, 2) // Capital emprunté
  remainingAmount Decimal @db.Decimal(15, 2) // CRD (Capital Restant Dû)
  monthlyPayment  Decimal @db.Decimal(12, 2) // Mensualité hors assurance

  // === TAUX ET CONDITIONS ===
  interestRate    Decimal   @db.Decimal(5, 4) // Taux nominal annuel
  effectiveRate   Decimal?  @db.Decimal(5, 4) // TAEG
  rateType        String? // FIXED, VARIABLE, CAPPED_VARIABLE
  variableCap     Decimal?  @db.Decimal(5, 2) // Plafond si variable
  deferralType    String? // NONE, PARTIAL, TOTAL
  deferralMonths  Int? // Nombre de mois de différé
  deferralEndDate DateTime? // Fin du différé

  // === DATES ===
  startDate        DateTime // Date de déblocage
  endDate          DateTime // Date de fin théorique
  firstPaymentDate DateTime? // Date première échéance
  lastPaymentDate  DateTime? // Date dernière échéance prévue

  // === RATTACHEMENT ACTIF ===
  linkedActifId String? // ID de l'actif financé
  linkedActif   Actif?  @relation(fields: [linkedActifId], references: [id], onDelete: SetNull)

  // === EMPRUNTEURS ===
  borrowerType         String? // SOLO, JOINT
  primaryBorrower      String? // Nom emprunteur principal
  primaryBorrowerQuota Decimal? @db.Decimal(5, 2) // Quotité emprunteur principal %
  coBorrower           String? // Nom co-emprunteur
  coBorrowerQuota      Decimal? @db.Decimal(5, 2) // Quotité co-emprunteur %
  borrowers            Json? // [{name, quota, isGuarantor}] pour cas complexes

  // === ASSURANCE EMPRUNTEUR ===
  insuranceType       String? // GROUPE, DELEGATION
  insuranceProvider   String? // Nom assureur
  insuranceRate       Decimal? @db.Decimal(5, 4) // Taux global %
  insuranceMonthly    Decimal? @db.Decimal(12, 2) // Prime mensuelle totale
  insuranceTotalCost  Decimal? @db.Decimal(15, 2) // Coût total assurance
  insuranceGuarantees Json? // [{type: 'DC'|'PTIA'|'ITT'|'IPT'|'IPP'|'PE', covered: true, quota: 100}]
  insuranceDetails    Json? // Détails par emprunteur [{borrower, guarantees, quota, monthlyPremium}]

  // === GARANTIES DU PRÊT ===
  guaranteeType        String? // HYPOTHEQUE, PPD, CAUTION_MUTUELLE, NANTISSEMENT, AUCUNE
  guaranteeProvider    String? // Crédit Logement, CASDEN, etc.
  guaranteeAmount      Decimal? @db.Decimal(15, 2) // Montant de la garantie
  guaranteeCost        Decimal? @db.Decimal(12, 2) // Frais de garantie
  guaranteeRestitution Decimal? @db.Decimal(12, 2) // Montant restituable (caution)

  // === PRÊTEUR ===
  lenderName     String? // Nom de la banque/organisme
  lenderType     String? // BANQUE, ORGANISME_CREDIT, PARTICULIER, EMPLOYEUR
  contractNumber String? // Numéro de contrat
  accountNumber  String? // Numéro de compte prélevé

  // === REMBOURSEMENT ANTICIPÉ ===
  earlyRepaymentAllowed    Boolean  @default(true)
  earlyRepaymentPenalty    Decimal? @db.Decimal(5, 2) // IRA %
  earlyRepaymentPenaltyMax Decimal? @db.Decimal(12, 2) // Plafond IRA €
  partialRepayments        Json? // [{date, amount, newMonthly, newEndDate}]

  // === RENÉGOCIATION / RACHAT ===
  isRenegotiated    Boolean   @default(false)
  originalRate      Decimal?  @db.Decimal(5, 4) // Ancien taux
  renegotiationDate DateTime? // Date de renégociation
  renegotiationCost Decimal?  @db.Decimal(12, 2) // Coût de la renégociation

  // === MODULARITÉ ===
  isModular       Boolean @default(false) // Mensualités modulables
  modularityRange Json? // {min: -30, max: +30} % de modularité
  pauseAllowed    Boolean @default(false) // Pause possible
  pauseMaxMonths  Int? // Nombre max de mois de pause

  // === CALCULS ===
  totalInterestCost Decimal? @db.Decimal(15, 2) // Coût total intérêts
  totalCost         Decimal? @db.Decimal(15, 2) // Coût total crédit (intérêts + assurance + frais)

  // Legacy
  insurance Json? // Ancien champ, garder pour rétrocompatibilité

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents PassifDocument[]

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@index([linkedActifId])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, clientId, isActive])
  @@index([clientId, type, isActive])
  @@index([endDate])
  @@map("passifs")
}

enum ContratType {
  ASSURANCE_VIE // Assurance-vie
  MUTUELLE // Mutuelle santé
  ASSURANCE_HABITATION // Assurance habitation
  ASSURANCE_AUTO // Assurance auto
  ASSURANCE_PRO // Assurance professionnelle
  ASSURANCE_DECES // Assurance décès
  PREVOYANCE // Prévoyance
  EPARGNE_RETRAITE // Épargne retraite
  AUTRE // Autre
}

enum ContratStatus {
  ACTIF // Actif
  SUSPENDU // Suspendu
  RESILIE // Résilié
  EXPIRE // Expiré
}

model Contrat {
  id              String        @id @default(cuid())
  cabinetId       String
  cabinet         Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            ContratType
  name            String
  provider        String
  contractNumber  String?
  startDate       DateTime
  endDate         DateTime?
  premium         Decimal?      @db.Decimal(12, 2)
  coverage        Decimal?      @db.Decimal(15, 2)
  value           Decimal?      @db.Decimal(15, 2)
  beneficiaries   Json?
  details         Json?
  commission      Decimal?      @db.Decimal(12, 2)
  nextRenewalDate DateTime?
  status          ContratStatus @default(ACTIF)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  documents ContratDocument[]

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@index([status])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, clientId, status])
  @@index([cabinetId, type, status])
  @@index([nextRenewalDate, status])
  @@map("contrats")
}

// ============================================
// MODULE 4: Documents et GED
// ============================================

enum DocumentType {
  CARTE_IDENTITE // Carte d'identité
  PASSEPORT // Passeport
  JUSTIFICATIF_DOMICILE // Justificatif de domicile
  AVIS_IMPOSITION // Avis d'imposition
  RELEVE_BANCAIRE // Relevé bancaire
  TITRE_PROPRIETE // Titre de propriété
  CONTRAT_PRET // Contrat de prêt
  CONTRAT_ASSURANCE // Contrat d'assurance
  RELEVE_PLACEMENT // Relevé de placement
  CONVENTION_ENTREE // Convention d'entrée
  LETTRE_MISSION // Lettre de mission
  DECLARATION_ADEQUATION // Déclaration d'adéquation
  PROFIL_INVESTISSEUR // Profil investisseur
  RAPPORT_ANNUEL // Rapport annuel
  PIECE_JOINTE_EMAIL // Pièce jointe email
  COMPTE_RENDU_RDV // Compte-rendu RDV
  PROPOSITION // Proposition
  CONTRAT // Contrat
  FACTURE // Facture
  AUTRE // Autre
}

enum DocumentCategory {
  IDENTITE
  FISCAL
  PATRIMOINE
  REGLEMENTAIRE
  COMMERCIAL
  AUTRE
}

enum SignatureStatus {
  EN_ATTENTE // En attente
  EN_COURS // En cours de signature
  SIGNE // Signé
  PARTIELLEMENT_SIGNE // Partiellement signé
  REJETE // Rejeté
  EXPIRE // Expiré
  ANNULE // Annulé
}

enum SignatureProvider {
  YOUSIGN // Yousign
  DOCUSIGN // DocuSign
  UNIVERSIGN // Universign
  INTERNE // Signature interne
  AUTRE // Autre fournisseur
}

model Document {
  id                  String             @id @default(cuid())
  cabinetId           String
  cabinet             Cabinet            @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  fileUrl             String
  fileSize            Int
  mimeType            String
  storageProvider     String             @default("LOCAL") // LOCAL, S3, AZURE, GCS
  storageBucket       String?
  storageKey          String?
  storageRegion       String?
  type                DocumentType
  category            DocumentCategory?
  tags                Json? // Array of tags
  metadata            Json? // Custom metadata
  version             Int                @default(1)
  parentVersionId     String?
  parentVersion       Document?          @relation("DocumentVersions", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions       Document[]         @relation("DocumentVersions")
  uploadedById        String
  uploadedBy          User               @relation("UploadedBy", fields: [uploadedById], references: [id])
  uploadedAt          DateTime           @default(now())
  signatureStatus     SignatureStatus?
  signatureProvider   SignatureProvider?
  signatureProviderId String? // External provider document ID
  signatureWorkflow   Json? // Workflow configuration and state
  signedAt            DateTime?
  signedBy            Json? // Array of signers with details
  expiresAt           DateTime?
  archivedAt          DateTime?
  isConfidential      Boolean            @default(false)
  accessLevel         String             @default("NORMAL") // NORMAL, RESTRICTED, CONFIDENTIAL
  checksum            String? // File integrity check
  downloadCount       Int                @default(0)
  lastAccessedAt      DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  clients        ClientDocument[]
  actifs         ActifDocument[]
  passifs        PassifDocument[]
  contrats       ContratDocument[]
  projets        ProjetDocument[]
  taches         TacheDocument[]
  templateId     String?
  template       DocumentTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  signatureSteps SignatureWorkflowStep[]

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([type])
  @@index([category])
  @@index([uploadedById])
  @@index([signatureStatus])
  @@index([expiresAt])
  @@index([archivedAt])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, type, category])
  @@index([cabinetId, uploadedById])
  @@map("documents")
}

model DocumentTemplate {
  id          String            @id @default(cuid())
  cabinetId   String
  cabinet     Cabinet           @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  name        String
  description String?
  type        DocumentType
  category    DocumentCategory?
  tags        Json?
  fileUrl     String? // Template file URL
  variables   Json? // Template variables for mail merge
  isActive    Boolean           @default(true)
  createdById String
  createdBy   User              @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  documents Document[]

  @@index([cabinetId])
  @@index([type])
  @@index([isActive])
  @@map("document_templates")
}

model SignatureWorkflowStep {
  id             String          @id @default(cuid())
  documentId     String
  document       Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  stepOrder      Int
  signerEmail    String
  signerName     String?
  signerRole     String?
  signatureType  String          @default("ELECTRONIC") // ELECTRONIC, ADVANCED, QUALIFIED
  status         SignatureStatus @default(EN_ATTENTE)
  signedAt       DateTime?
  signatureData  Json? // Signature metadata from provider
  reminderSentAt DateTime?
  reminderCount  Int             @default(0)
  expiresAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([documentId])
  @@index([status])
  @@index([signerEmail])
  @@map("signature_workflow_steps")
}

model ClientDocument {
  id         String   @id @default(cuid())
  clientId   String
  documentId String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([clientId, documentId])
  @@index([clientId])
  @@index([documentId])
  @@map("client_documents")
}

model ActifDocument {
  id         String   @id @default(cuid())
  actifId    String
  documentId String
  actif      Actif    @relation(fields: [actifId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([actifId, documentId])
  @@map("actif_documents")
}

model PassifDocument {
  id         String   @id @default(cuid())
  passifId   String
  documentId String
  passif     Passif   @relation(fields: [passifId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([passifId, documentId])
  @@map("passif_documents")
}

model ContratDocument {
  id         String   @id @default(cuid())
  contratId  String
  documentId String
  contrat    Contrat  @relation(fields: [contratId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([contratId, documentId])
  @@map("contrat_documents")
}

enum KYCDocumentType {
  IDENTITE // Pièce d'identité
  JUSTIFICATIF_DOMICILE // Justificatif de domicile
  AVIS_IMPOSITION // Avis d'imposition
  RIB_BANCAIRE // RIB bancaire
  JUSTIFICATIF_PATRIMOINE // Justificatif de patrimoine
  ORIGINE_FONDS // Origine des fonds
  AUTRE // Autre document
}

enum KYCDocStatus {
  EN_ATTENTE // En attente de validation
  VALIDE // Validé
  REJETE // Rejeté
  EXPIRE // Expiré
}

model KYCDocument {
  id              String          @id @default(cuid())
  cabinetId       String
  cabinet         Cabinet         @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            KYCDocumentType
  documentId      String?
  fileName        String?
  fileUrl         String?
  status          KYCDocStatus    @default(EN_ATTENTE)
  validatedAt     DateTime?
  validatedById   String?
  validatedBy     User?           @relation("KYCDocumentValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  rejectionReason String?         @db.Text
  expiresAt       DateTime?
  reminderSentAt  DateTime?
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([clientId])
  @@index([status])
  @@index([expiresAt])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, clientId, status])
  @@index([expiresAt, status])
  @@map("kyc_documents")
}

enum KYCCheckType {
