enum InvoiceStatus {
  BROUILLON // Brouillon
  ENVOYEE // Envoyée au client
  PAYEE // Payée intégralement
  EN_RETARD // En retard de paiement
  ANNULEE // Annulée
}

enum PaymentMethod {
  VIREMENT // Virement bancaire
  CHEQUE // Chèque
  ESPECES // Espèces
  CARTE_BANCAIRE // Carte bancaire
  AUTRE // Autre
}

model Invoice {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Numérotation unique
  invoiceNumber String // Format: INV-2024-001

  // Client facturé
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Conseiller émetteur
  conseillerId String
  conseiller   User   @relation("ConseillerInvoices", fields: [conseillerId], references: [id])

  // Montants en euros
  amountHT  Decimal @db.Decimal(12, 2) // Montant hors taxes
  tva       Decimal @db.Decimal(5, 2) // Taux de TVA (ex: 20.00 pour 20%)
  amountTTC Decimal @db.Decimal(12, 2) // Montant toutes taxes comprises

  // Statut et dates
  status    InvoiceStatus @default(BROUILLON)
  issueDate DateTime      @default(now()) // Date d'émission
  dueDate   DateTime // Date d'échéance
  paidDate  DateTime? // Date de paiement effectif

  // Description et notes
  description        String? @db.Text
  notes              String? @db.Text
  termsAndConditions String? @db.Text

  // Lignes de facturation
  items InvoiceItem[]

  // Paiements associés
  payments Payment[]

  // Relations optionnelles avec projets/opportunités
  projectId String?
  project   Projet? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   Opportunite? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  // Document PDF généré
  pdfUrl         String?
  pdfGeneratedAt DateTime?

  // Commissions liées
  commissions Commission[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cabinetId, invoiceNumber])
  // INDEX EXISTANTS
  @@index([cabinetId, clientId])
  @@index([cabinetId, conseillerId])
  @@index([cabinetId, status])
  @@index([issueDate])
  @@index([dueDate])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, status, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Ordre d'affichage
  order Int @default(0)

  // Description du service/produit
  description String @db.Text

  // Quantité et prix unitaire
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(12, 2)

  // Montants calculés
  totalHT  Decimal @db.Decimal(12, 2) // quantity * unitPrice
  tva      Decimal @db.Decimal(5, 2) // Taux TVA pour cette ligne
  totalTTC Decimal @db.Decimal(12, 2) // totalHT * (1 + tva/100)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String @id @default(cuid())
  cabinetId String

  // Facture associée
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Montant du paiement
  amount Decimal @db.Decimal(12, 2)

  // Méthode de paiement
  method PaymentMethod @default(VIREMENT)

  // Référence du paiement (numéro chèque, virement, etc.)
  reference String?

  // Date du paiement
  paidAt DateTime @default(now())

  // Notes optionnelles
  notes String? @db.Text

  // Metadata
  createdAt DateTime @default(now())

  @@index([cabinetId, invoiceId])
  @@index([paidAt])
  @@map("payments")
}

enum ApporteurEntityType {
  PERSONNE_PHYSIQUE // Personne physique
  SOCIETE // Société
}

enum CommissionType {
  POURCENTAGE // Pourcentage du CA
  MONTANT_FIXE // Montant fixe
}

enum CommissionStatus {
  EN_ATTENTE // En attente
  VALIDEE // Validée/Approuvée
  PAYEE // Payée
  ANNULEE // Annulée
}

model Apporteur {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Type d'apporteur
  type ApporteurEntityType @default(PERSONNE_PHYSIQUE)

  // Identité personne physique
  firstName String?
  lastName  String?

  // Identité société
  companyName String?

  // Contact
  email      String
  phone      String?
  address    String? @db.Text
  city       String?
  postalCode String?
  country    String  @default("France")

  // Informations professionnelles
  siret     String? // Numéro SIRET
  tvaNumber String? // Numéro TVA intracommunautaire
  iban      String? // IBAN pour virements
  bic       String? // BIC/SWIFT

  // Configuration commission
  commissionRate Decimal        @db.Decimal(5, 2) // Ex: 10.00 pour 10%
  commissionType CommissionType @default(POURCENTAGE)

  // Relations
  clients     Client[]     @relation("ApporteurClients")
  commissions Commission[]

  // Statut
  isActive Boolean @default(true)

  // Notes et remarques
  notes String? @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cabinetId, email])
  @@index([cabinetId, isActive])
  @@index([cabinetId, type])
  @@map("apporteurs")
}

model Commission {
  id        String @id @default(cuid())
  cabinetId String

  // Apporteur bénéficiaire
  apporteurId String
  apporteur   Apporteur @relation(fields: [apporteurId], references: [id], onDelete: Cascade)

  // Client concerné
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Facture optionnelle liée
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Montant de la commission
  amount Decimal @db.Decimal(12, 2)

  // Taux appliqué
  rate Decimal @db.Decimal(5, 2) // Ex: 10.00 pour 10%

  // Type de commission
  type CommissionType @default(POURCENTAGE)

  // Statut
  status CommissionStatus @default(EN_ATTENTE)

  // Dates
  paidAt DateTime?

  // Description et notes
  description String? @db.Text
  notes       String? @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cabinetId, apporteurId])
  @@index([cabinetId, clientId])
  @@index([cabinetId, status])
  @@index([cabinetId, invoiceId])
  @@map("commissions")
}

