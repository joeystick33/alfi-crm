  cabinet      Cabinet?    @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Permissions
  permissions Json? // Liste des permissions accordées

  // Statut
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  // Usage
  lastUsedAt   DateTime?
  requestCount Int       @default(0)

  @@index([key])
  @@index([superAdminId])
  @@index([cabinetId])
  @@index([isActive])
  @@map("api_keys")
}

// Statuts des webhooks
enum WebhookStatus {
  ACTIF // Actif
  INACTIF // Inactif
  ERREUR // En erreur
}

// Endpoints webhook pour notifications
model WebhookEndpoint {
