  createdAt  DateTime        @default(now())
  
  @@index([cabinetId])
  @@index([quotaName])
  @@index([createdAt])
  @@map("quota_alerts")
}

// Modèle pour la synchronisation calendrier
enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

model CalendarSync {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
