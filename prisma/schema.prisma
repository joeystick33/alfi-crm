  updatedById String?

  @@index([category])
  @@map("system_configs")
}

// Clés API pour accès programmatique
model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identification
  name   String
  key    String @unique // Hashée
  prefix String // Préfixe visible (ex: ak_live_)

