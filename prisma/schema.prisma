enum DossierPriorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

model Dossier {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Identification
  reference   String // Référence unique du dossier (ex: DOS-2024-001)
  nom         String // Nom du dossier
  description String? @db.Text

  // Statut et typologie
  status    DossierStatus    @default(BROUILLON)
  categorie DossierCategorie @default(AUTRE)
  type      DossierType      @default(AUTRE)
  priorite  DossierPriorite  @default(NORMALE)

  // Client concerné
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Conseiller responsable
  conseillerId String
  conseiller   User   @relation("ConseillerDossiers", fields: [conseillerId], references: [id], onDelete: Restrict)

  // Dates du dossier
  dateOuverture     DateTime  @default(now())
  dateCloturePrevu  DateTime? // Date de clôture prévue
  dateClotureReelle DateTime? // Date de clôture réelle

  // Informations financières
  montantEstime  Decimal? @db.Decimal(15, 2) // Montant estimé du dossier
  montantRealise Decimal? @db.Decimal(15, 2) // Montant réalisé
  budgetAlloue   Decimal? @db.Decimal(15, 2) // Budget alloué

  // Avancement
  progressionPct Int @default(0) // Progression en pourcentage (0-100)

  // Relations avec autres entités
  projets      Projet[]
  opportunites Opportunite[]
  taches       Tache[]
  rendezvous   RendezVous[]

  // Notes et commentaires
  notes           String? @db.Text
  objetifs        String? @db.Text // Objectifs du dossier
  risques         String? @db.Text // Risques identifiés
  recommandations String? @db.Text // Recommandations

  // Metadata
  tags       String[] // Tags pour catégorisation
  isArchive  Boolean   @default(false)
  archivedAt DateTime?
  archivedBy String? // ID du conseiller qui a archivé

  // Workflow intégré
  etapeActuelle         DossierEtape  @default(COLLECTE)
  clientDataSnapshot    Json?         // Copie des données client au moment création

  // Relations dossier intégré
  simulations           DossierSimulation[]
  preconisations        DossierPreconisation[]
  documentsGeneres      DossierDocument[]

  @@unique([cabinetId, reference])
  // INDEX EXISTANTS
  @@index([cabinetId, clientId])
  @@index([cabinetId, conseillerId])
  @@index([cabinetId, status])
  @@index([cabinetId, type])
  @@index([cabinetId, priorite])
  @@index([cabinetId, dateOuverture])
  @@index([clientId, status])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, status, priorite])
  @@index([dateCloturePrevu, status])
  @@map("dossiers")
}

// Étapes du workflow dossier
enum DossierEtape {
  COLLECTE      // Import données client
  ANALYSE       // Simulations et étude
  PRECONISATION // Rédaction recommandations
  VALIDATION    // Validation client
  CLOTURE       // Dossier finalisé
}

// Types de simulateurs
enum SimulateurType {
  FISCAL_IR
  FISCAL_ENVELOPPE
  FISCAL_STRATEGIE
  RETRAITE
  RETRAITE_COMPARATIF
  PENSION
  PER_SALARIES
  PER_TNS
  SUCCESSION
  SUCCESSION_COMPARATIF
  DONATION
  CAPACITE_EMPRUNT
  MENSUALITE
  PTZ
  IMMOBILIER_RENDEMENT
  LMNP
  EPARGNE
  ASSURANCE_VIE
  PREVOYANCE_TNS
  AUTRE
}

// Simulations effectuées dans un dossier
model DossierSimulation {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  dossierId     String
  dossier       Dossier        @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  simulateurType SimulateurType
  nom            String         // Nom donné à la simulation
  parametres     Json           // Paramètres d'entrée
  resultats      Json           // Résultats calculés
  selectionne    Boolean        @default(false) // Inclure dans le PDF
  ordre          Int            @default(0)     // Ordre d'affichage

  @@index([dossierId])
  @@index([dossierId, simulateurType])
  @@map("dossier_simulations")
}

// Types de documents générés pour dossiers
enum DossierDocumentType {
  BILAN_PATRIMONIAL
  RAPPORT_CONSEIL
  SIMULATION_DETAIL
  RECUEIL_BESOINS
  PROPOSITION_COMMERCIALE
  LETTRE_MISSION
  MANDAT
  AUTRE
}

// Préconisations du conseiller
model DossierPreconisation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dossierId     String
  dossier       Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  titre         String
  description   String   @db.Text
  argumentaire  String?  @db.Text  // Justification de la préconisation
  produitId     String?            // Lien vers produit du catalogue (optionnel)
  montant       Decimal? @db.Decimal(15, 2)
  priorite      Int      @default(1)
  ordre         Int      @default(0)
  statut        PreconisationStatut @default(PROPOSEE)

  @@index([dossierId])
  @@index([dossierId, statut])
  @@map("dossier_preconisations")
}

enum PreconisationStatut {
  PROPOSEE
  ACCEPTEE
  REFUSEE
  EN_COURS
  REALISEE
}

// Documents générés (PDF, etc.)
model DossierDocument {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())

  dossierId     String
  dossier       Dossier      @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  type          DossierDocumentType
  nom           String
  url           String       // URL du fichier stocké
  taille        Int          // Taille en bytes
  version       Int          @default(1)
  genereParId   String?      // ID du conseiller qui a généré

  @@index([dossierId])
  @@index([dossierId, type])
  @@map("dossier_documents")
}

