// ============================================
// MODULE 7: Tâches et Agenda
// ============================================

enum TacheType {
  APPEL // Appel téléphonique
  EMAIL // Email
  REUNION // Réunion
  REVUE_DOCUMENTS // Revue documents
  MISE_A_JOUR_KYC // Mise à jour KYC
  RENOUVELLEMENT_CONTRAT // Renouvellement contrat
  SUIVI // Suivi
  ADMINISTRATIF // Administratif
  AUTRE // Autre
}

enum TachePriority {
  BASSE // Basse
  MOYENNE // Moyenne
  HAUTE // Haute
  URGENTE // Urgente
}

enum TacheStatus {
  A_FAIRE // À faire
  EN_COURS // En cours
  TERMINE // Terminé
  ANNULE // Annulé
}

model Tache {
  id           String        @id @default(cuid())
  cabinetId    String
  cabinet      Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User          @relation(fields: [assignedToId], references: [id])
  clientId     String?
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projetId     String?
  projet       Projet?       @relation(fields: [projetId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User          @relation("TacheCreatedBy", fields: [createdById], references: [id])
  title        String
  description  String?
  type         TacheType
  priority     TachePriority @default(MOYENNE)
  status       TacheStatus   @default(A_FAIRE)
  dueDate      DateTime?
  completedAt  DateTime?
  reminderDate DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relation optionnelle avec dossier
  dossierId String?
  dossier   Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)

  documents TacheDocument[]

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([assignedToId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, assignedToId, status])
  @@index([cabinetId, assignedToId, status, dueDate])
  @@index([cabinetId, clientId, status])
  @@index([dueDate, status])
  @@map("taches")
}

model TacheDocument {
  id         String   @id @default(cuid())
  tacheId    String
  documentId String
  tache      Tache    @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([tacheId, documentId])
  @@map("tache_documents")
}

enum RendezVousType {
  PREMIER_RDV // Premier rendez-vous
  SUIVI // Suivi
  BILAN_ANNUEL // Bilan annuel
  SIGNATURE // Signature
  APPEL_TEL // Appel téléphonique
  VISIO // Visioconférence
  AUTRE // Autre
}

enum RendezVousStatus {
  PLANIFIE // Planifié
  CONFIRME // Confirmé
  TERMINE // Terminé
  ANNULE // Annulé
  ABSENT // Absent
}

model RendezVous {
  id                 String           @id @default(cuid())
  cabinetId          String
  cabinet            Cabinet          @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  conseillerId       String
  conseiller         User             @relation("ConseillerRendezVous", fields: [conseillerId], references: [id])
  clientId           String?
  client             Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  type               RendezVousType
  startDate          DateTime
  endDate            DateTime
  location           String?
  isVirtual          Boolean          @default(false)
  meetingUrl         String?
  status             RendezVousStatus @default(PLANIFIE)
  reminderSent       Boolean          @default(false)
  notes              String?
  hasMinutes         Boolean          @default(false)
  minutesDocId       String?
  externalCalendarId String?
  externalEventId    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cancelledAt        DateTime?

  // Récurrence (RFC 5545 iCal)
  isRecurring          Boolean   @default(false)
  recurrenceRule       String? // Format RRULE: FREQ=WEEKLY;BYDAY=MO,WE;COUNT=10
  recurrenceEndDate    DateTime? // Date de fin de la récurrence
  recurrenceExceptions String? // JSON array de dates ISO exclues

  // Lien avec série récurrente (pour occurrences modifiées)
  parentRecurrenceId       String?
  parentRecurrence         RendezVous?  @relation("RecurrenceSeries", fields: [parentRecurrenceId], references: [id], onDelete: Cascade)
  recurrenceInstances      RendezVous[] @relation("RecurrenceSeries")
  recurrenceOccurrenceDate DateTime? // Date spécifique de cette occurrence

  // Historique replanification
  originalStartDate DateTime? // Date initiale avant toute modification
  rescheduledAt     DateTime? // Timestamp de la dernière replanification
  rescheduledCount  Int       @default(0)
  rescheduledBy     String? // ID de l'utilisateur ayant replanifié
  rescheduledByUser User?     @relation("RescheduledBy", fields: [rescheduledBy], references: [id])

  // Relation optionnelle avec dossier
  dossierId String?
  dossier   Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)

  // INDEX EXISTANTS
  @@index([cabinetId])
  @@index([conseillerId])
  @@index([clientId])
  @@index([startDate])
  @@index([status])
  @@index([parentRecurrenceId])
  @@index([recurrenceOccurrenceDate])
  @@index([isRecurring])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, conseillerId, status])
  @@index([cabinetId, conseillerId, startDate])
  @@index([cabinetId, clientId, startDate])
  @@index([startDate, status])
  @@map("rendez_vous")
}

enum CalendarProvider {
  OUTLOOK
  GOOGLE
  APPLE
}

model CalendarSync {
  id             String           @id @default(cuid())
  userId         String           @unique
  provider       CalendarProvider
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  calendarId     String?
  syncEnabled    Boolean          @default(true)
  lastSyncAt     DateTime?
  lastSyncStatus String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("calendar_syncs")
}

model Event {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean  @default(false)
  location    String?
  type        String   @default("MEETING") // MEETING, CALL, REMINDER, APPOINTMENT
  status      String   @default("CONFIRMED") // CONFIRMED, TENTATIVE, CANCELLED

  // Relations
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // Appointment booking fields
  isBookedByClient Boolean  @default(false)  // true si réservé via page publique
  bookingNotes     String?  @db.Text         // Notes du client lors de la réservation
  reminderSentAt   DateTime?                 // Date d'envoi du rappel
  confirmationSentAt DateTime?               // Date d'envoi de la confirmation
  videoLink        String?                   // Lien visio (Google Meet, Zoom, etc.)
  appointmentTypeId String?
  appointmentType   AppointmentType? @relation(fields: [appointmentTypeId], references: [id])

  // External Sync
  externalId       String? // ID from Google/Outlook
  externalProvider CalendarProvider?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cabinetId])
  @@index([userId])
  @@index([clientId])
  @@index([startDate, endDate])
  @@index([appointmentTypeId])
  @@map("events")
}

// Types de rendez-vous configurables par le conseiller
model AppointmentType {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String            // "Découverte", "Suivi annuel", "Bilan patrimonial"
  slug        String            // URL-friendly slug
  description String?  @db.Text
  duration    Int               // Durée en minutes (30, 45, 60, 90, 120)
  color       String  @default("#2B7A78")
  location    String?           // Lieu par défaut (bureau, visio, domicile)
  isActive    Boolean @default(true)
  isPublic    Boolean @default(true) // Visible sur la page publique
  price       Float?              // Honoraires éventuels
  requiresApproval Boolean @default(false) // Nécessite validation du conseiller

  // Paramètres de créneau
  bufferBefore Int @default(0)  // Minutes de battement avant
  bufferAfter  Int @default(15) // Minutes de battement après
  maxPerDay    Int @default(8)  // Nombre max par jour

  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slug])
  @@index([cabinetId])
  @@index([userId])
  @@map("appointment_types")
}

// Disponibilités hebdomadaires du conseiller
model Availability {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayOfWeek Int     // 0=Dimanche, 1=Lundi, ... 6=Samedi
  startTime String  // Format "HH:mm" ex: "09:00"
  endTime   String  // Format "HH:mm" ex: "18:00"
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("availabilities")
}

// Indisponibilités ponctuelles (vacances, formation, etc.)
model BlockedSlot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  reason    String?
  allDay    Boolean  @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([startDate, endDate])
  @@map("blocked_slots")
}

// ============================================
// MODULE 8: Communications
// ============================================

enum EmailStatus {
  BROUILLON // Brouillon
  PLANIFIE // Planifié
  ENVOYE // Envoyé
  DELIVRE // Délivré
  OUVERT // Ouvert
  CLIQUE // Cliqué
  REBOND // Rebond
  ECHEC // Échec
}

model Email {
  id          String      @id @default(cuid())
  cabinetId   String
  cabinet     Cabinet     @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation(fields: [senderId], references: [id])
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject     String
  body        String      @db.Text
  to          Json
  cc          Json?
  bcc         Json?
  attachments Json?
  status      EmailStatus @default(BROUILLON)
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  templateId  String?
  campagneId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([cabinetId])
  @@index([senderId])
  @@index([clientId])
  @@index([status])
  @@index([sentAt])
  @@map("emails")
}

enum EmailProvider {
  GMAIL
  OUTLOOK
}

enum EmailDirection {
  ENTRANT // Email reçu
  SORTANT // Email envoyé
}

// Emails synchronisés depuis Gmail/Outlook
model SyncedEmail {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Identifiants externes
  externalId String // ID Gmail/Outlook
  threadId   String? // Thread ID
  provider   EmailProvider

  // Contenu
  from     String
  to       Json // Array of emails
  cc       Json? // Array of emails
  bcc      Json? // Array of emails
  subject  String
  body     String  @db.Text
  bodyHtml String? @db.Text
  snippet  String? // Preview

  // Métadonnées
  direction      EmailDirection
  isRead         Boolean        @default(false)
  hasAttachments Boolean        @default(false)
  labels         Json? // Array of labels/categories

  // Classification automatique
  autoClassified Boolean @default(false)
  classifiedAs   Json? // Array: CLIENT, PROSPECT, INTERNAL, IMPORTANT

  // Dates
  sentAt     DateTime
  receivedAt DateTime
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  attachments EmailAttachment[]
  replies     EmailReply[]

  @@unique([externalId, provider])
  @@index([cabinetId])
  @@index([userId])
  @@index([clientId])
  @@index([provider])
  @@index([isRead])
  @@index([sentAt])
  @@index([receivedAt])
  @@map("synced_emails")
}

// Pièces jointes d'emails
model EmailAttachment {
  id            String      @id @default(cuid())
  syncedEmailId String
  syncedEmail   SyncedEmail @relation(fields: [syncedEmailId], references: [id], onDelete: Cascade)

  filename   String
  mimeType   String
  size       Int // Size in bytes
  url        String? // URL de téléchargement (si stocké)
  externalId String? // ID externe (Gmail/Outlook)

  createdAt DateTime @default(now())

  @@index([syncedEmailId])
  @@map("email_attachments")
}

// Réponses rapides aux emails
model EmailReply {
  id            String      @id @default(cuid())
  syncedEmailId String
  syncedEmail   SyncedEmail @relation(fields: [syncedEmailId], references: [id], onDelete: Cascade)
  userId        String

  body       String        @db.Text
  sentAt     DateTime
  sentVia    EmailProvider
  externalId String? // ID de l'email envoyé

  createdAt DateTime @default(now())

  @@index([syncedEmailId])
  @@index([userId])
  @@map("email_replies")
}

// Templates d'emails
model EmailTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  // Identification
  name        String
  description String? @db.Text
  category    String? // PROSPECTION, SUIVI, RELANCE, BIENVENUE, NEWSLETTER, etc.

  // Contenu
  subject      String
  previewText  String? // Texte preview email
  htmlContent  String  @db.Text // body HTML (nouveau nom pour bodyHtml)
  plainContent String? @db.Text // body texte brut (ancien body)

  // Variables disponibles
  variables String[] // Liste variables utilisables (ex: {{firstName}}, {{clientName}})

  // Créateur
  createdBy     String
  createdByUser User   @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  // Statut
  isActive   Boolean @default(true)
  isSystem   Boolean @default(false) // Template système (non modifiable)
  isArchived Boolean @default(false)

  // Utilisation par modules marketing
  campaigns Campaign[]
  scenarios Scenario[]
  messages  EmailMessage[]

  // Metadata
  tags  String[]
  notes String?  @db.Text

  @@index([cabinetId])
  @@index([cabinetId, isActive])
  @@index([category])
  @@map("email_templates")
}

// Configuration de synchronisation email par utilisateur
model EmailIntegration {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider EmailProvider
  email    String // Email address connected

  // OAuth tokens
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  scope        String?

  // Sync settings
  syncEnabled    Boolean   @default(true)
  syncFrequency  Int       @default(5) // minutes
  lastSyncAt     DateTime?
  lastSyncStatus String?
  nextSyncToken  String?   @db.Text // For incremental sync

  // Preferences
  autoClassify    Boolean @default(true)
  autoMatchClient Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([provider])
  @@index([syncEnabled])
  @@map("email_integrations")
}

