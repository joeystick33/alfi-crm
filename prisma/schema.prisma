enum OpportuniteType {
  ASSURANCE_VIE // Assurance-vie
  EPARGNE_RETRAITE // Épargne retraite (PER, PERP...)
  INVESTISSEMENT_IMMOBILIER // Investissement immobilier
  INVESTISSEMENT_FINANCIER // Investissement financier (CTO, PEA...)
  OPTIMISATION_FISCALE // Optimisation fiscale
  RESTRUCTURATION_CREDIT // Restructuration de crédit
  TRANSMISSION_PATRIMOINE // Transmission de patrimoine
  AUDIT_ASSURANCES // Audit des assurances
  AUTRE // Autre opportunité
}

enum OpportunitePriority {
  BASSE // Basse
  MOYENNE // Moyenne
  HAUTE // Haute
  URGENTE // Urgente
}

enum OpportuniteStatus {
  DETECTEE // Détectée
  QUALIFIEE // Qualifiée
  CONTACTEE // Contactée
  PRESENTEE // Présentée
  ACCEPTEE // Acceptée
  CONVERTIE // Convertie
  REJETEE // Rejetée
  PERDUE // Perdue
}

model Opportunite {
  id                  String              @id @default(cuid())
  cabinetId           String
  cabinet             Cabinet             @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  conseillerId        String
  conseiller          User                @relation(fields: [conseillerId], references: [id])
  clientId            String
  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type                OpportuniteType
  name                String
  description         String?
  estimatedValue      Decimal?            @db.Decimal(15, 2)
  score               Int?                @default(0)
  confidence          Decimal?            @db.Decimal(5, 2)
  priority            OpportunitePriority @default(MOYENNE)
  status              OpportuniteStatus   @default(DETECTEE)
  stage               String?
  detectedAt          DateTime            @default(now())
  qualifiedAt         DateTime?
  contactedAt         DateTime?
  presentedAt         DateTime?
  acceptedAt          DateTime?
  convertedAt         DateTime?
  rejectedAt          DateTime?
  actionDeadline      DateTime?
  rejectionReason     String?
  convertedToProjetId String?
  actions             Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relation optionnelle avec dossier
  dossierId String?
  dossier   Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)

  invoices Invoice[]

