// Prisma Schema pour ALFI CRM
// Base de données: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// MODULE 1: Multi-Tenant et Utilisateurs
// ============================================

enum SuperAdminRole {
  OWNER
  ADMIN
  DEVELOPER
  SUPPORT
}

model SuperAdmin {
  id          String         @id @default(cuid())
  email       String         @unique
  password    String
  firstName   String
  lastName    String
  role        SuperAdminRole @default(ADMIN)
  permissions Json?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lastLogin   DateTime?
  
  auditLogs   AuditLog[]
  
  @@index([email])
  @@index([isActive])
  @@map("super_admins")
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  BUSINESS
  PREMIUM
  ENTERPRISE
  CUSTOM
}

enum CabinetStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  TERMINATED
  TRIALING
}

model Cabinet {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  email             String
  phone             String?
  address           Json?
  plan              SubscriptionPlan @default(TRIAL)
  status            CabinetStatus    @default(TRIALING)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  trialEndsAt       DateTime?
  quotas            Json?
  usage             Json?
  features          Json?
  restrictions      Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?
  
  users             User[]
  clients           Client[]
  actifs            Actif[]
  passifs           Passif[]
  contrats          Contrat[]
  documents         Document[]
  taches            Tache[]
  rendezvous        RendezVous[]
  objectifs         Objectif[]
  projets           Projet[]
  opportunites      Opportunite[]
  campagnes         Campagne[]
  emails            Email[]
  notifications     Notification[]
  templates         Template[]
  apporteurs        ApporteurAffaires[]
  simulations       Simulation[]
  auditLogs         AuditLog[]
  
  @@index([slug])
  @@index([status])
  @@index([plan])
  @@map("cabinets")
}

enum UserRole {
  ADMIN
  ADVISOR
  ASSISTANT
}

model User {
  id          String   @id @default(cuid())
  cabinetId   String
  cabinet     Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  avatar      String?
  role        UserRole @default(ADVISOR)
  permissions Json?
  stats       Json?
  preferences Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLogin   DateTime?
  
  clientsPrincipaux     Client[]              @relation("ConseillerPrincipal")
  clientsRemplacants    Client[]              @relation("ConseillerRemplacant")
  assistantAssignments  AssistantAssignment[]
  taches                Tache[]
  tachesCreated         Tache[]               @relation("TacheCreatedBy")
  rendezvous            RendezVous[]
  opportunites          Opportunite[]
  campagnes             Campagne[]
  emails                Email[]
  documents             Document[]            @relation("UploadedBy")
  apporteurs            ApporteurAffaires[]
  simulations           Simulation[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  calendarSyncs         CalendarSync[]
  
  @@index([cabinetId])
  @@index([cabinetId, role])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model AssistantAssignment {
  id          String   @id @default(cuid())
  cabinetId   String
  assistantId String
  advisorId   String
  assistant   User     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([assistantId, advisorId])
  @@index([cabinetId])
  @@index([assistantId])
  @@index([advisorId])
  @@map("assistant_assignments")
}

enum ApporteurType {
  NOTAIRE
  EXPERT_COMPTABLE
  BANQUIER
  COURTIER
  AUTRE
}

model ApporteurAffaires {
  id             String        @id @default(cuid())
  cabinetId      String
  cabinet        Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  ownerId        String?
  owner          User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  type           ApporteurType
  firstName      String
  lastName       String
  email          String
  phone          String?
  company        String?
  profession     String?
  commissionRate Decimal?      @db.Decimal(5, 2)
  stats          Json?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  clients        Client[]
  
  @@index([cabinetId])
  @@index([ownerId])
  @@index([type])
  @@map("apporteurs_affaires")
}

// ============================================
// MODULE 2: Gestion des Clients
// ============================================

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  PACS
  COHABITATION
}

enum RiskProfile {
  CONSERVATEUR    // Conservateur - Sécurité maximale
  PRUDENT         // Prudent - Risque faible
  EQUILIBRE       // Équilibré - Risque modéré
  DYNAMIQUE       // Dynamique - Risque élevé
  OFFENSIF        // Offensif - Risque maximum
}

enum InvestmentHorizon {
  SHORT
  MEDIUM
  LONG
}

enum KYCStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  REJECTED
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  ARCHIVED
  LOST
}

enum ClientType {
  PARTICULIER
  PROFESSIONNEL
}

model Client {
  id                     String          @id @default(cuid())
  cabinetId              String
  cabinet                Cabinet         @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  
  // Type de client (Particulier ou Professionnel)
  clientType             ClientType      @default(PARTICULIER)
  conseillerId           String
  conseiller             User            @relation("ConseillerPrincipal", fields: [conseillerId], references: [id])
  conseillerRemplacantId String?
  conseillerRemplacant   User?           @relation("ConseillerRemplacant", fields: [conseillerRemplacantId], references: [id])
  apporteurId            String?
  apporteur              ApporteurAffaires? @relation(fields: [apporteurId], references: [id], onDelete: SetNull)
  
  email                  String?
  firstName              String
  lastName               String
  birthDate              DateTime?
  birthPlace             String?
  nationality            String?
  phone                  String?
  mobile                 String?
  address                Json?
  
  maritalStatus          MaritalStatus?
  marriageRegime         String?
  numberOfChildren       Int?            @default(0)
  
  profession             String?
  employerName           String?
  professionalStatus     String?
  
  // Informations spécifiques pour clients PROFESSIONNELS
  companyName            String?         // Nom de l'entreprise
  siret                  String?         // SIRET
  legalForm              String?         // SARL, SAS, SA, etc.
  activitySector         String?         // Secteur d'activité
  companyCreationDate    DateTime?       // Date de création
  numberOfEmployees      Int?            // Nombre de salariés
  annualRevenue          Decimal?        @db.Decimal(15, 2) // CA annuel
  
  annualIncome           Decimal?        @db.Decimal(12, 2)
  taxBracket             String?
  fiscalResidence        String?
  
  // Fiscalité détaillée
  irTaxRate              Decimal?        @db.Decimal(5, 2) // Taux marginal IR (%)
  ifiSubject             Boolean         @default(false)   // Soumis à l'IFI
  ifiAmount              Decimal?        @db.Decimal(15, 2) // Montant IFI payé
  taxOptimizations       Json?           // Défiscalisations effectuées (Pinel, Malraux, etc.)
  fiscalNotes            String?         @db.Text // Notes fiscales
  
  // Profil investisseur (MiFID II)
  riskProfile            RiskProfile?
  investmentHorizon      InvestmentHorizon?
  investmentGoals        Json?
  investmentKnowledge    String?         // Niveau de connaissance financière
  investmentExperience   String?         // Expérience en investissement
  
  // Patrimoine (calculé automatiquement)
  wealth                 Json?           // { totalAssets, totalLiabilities, netWealth, managedAssets, unmanagedAssets, lastCalculated }
  
  // Gestion du patrimoine
  managedByFirm          Boolean         @default(false)   // Patrimoine géré par le cabinet
  managementStartDate    DateTime?       // Date de début de gestion
  managementFees         Decimal?        @db.Decimal(5, 2) // Frais de gestion (%)
  managementType         String?         // Type de mandat (conseil, gestion pilotée, etc.)
  
  kycStatus              KYCStatus       @default(PENDING)
  kycCompletedAt         DateTime?
  kycNextReviewDate      DateTime?
  
  status                 ClientStatus    @default(PROSPECT)
  
  portalAccess           Boolean         @default(false)
  portalPassword         String?
  lastPortalLogin        DateTime?
  
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  lastContactDate        DateTime?
  
  familyMembers          FamilyMember[]
  actifs                 ClientActif[]
  passifs                Passif[]
  contrats               Contrat[]
  objectifs              Objectif[]
  projets                Projet[]
  opportunites           Opportunite[]
  taches                 Tache[]
  rendezvous             RendezVous[]
  documents              ClientDocument[]
  emails                 Email[]
  notifications          Notification[]
  simulations            Simulation[]
  kycDocuments           KYCDocument[]
  consentements          Consentement[]
  reclamations           Reclamation[]
  timelineEvents         TimelineEvent[]
  
  @@index([cabinetId])
  @@index([conseillerId])
  @@index([cabinetId, conseillerId])
  @@index([status])
  @@index([clientType])
  @@index([cabinetId, clientType, status])
  @@index([kycStatus])
  @@index([email])
  @@map("clients")
}

enum FamilyRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDCHILD
  OTHER
}

model FamilyMember {
  id             String             @id @default(cuid())
  clientId       String
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  birthDate      DateTime?
  relationship   FamilyRelationship
  linkedClientId String?
  isBeneficiary  Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  @@index([clientId])
  @@map("family_members")
}

// ============================================
// MODULE 3: Gestion du Patrimoine
// ============================================

enum ActifType {
  REAL_ESTATE_MAIN
  REAL_ESTATE_RENTAL
  REAL_ESTATE_SECONDARY
  SCPI
  SCI
  LIFE_INSURANCE
  SECURITIES_ACCOUNT
  PEA
  PEA_PME
  BANK_ACCOUNT
  SAVINGS_ACCOUNT
  PEL
  CEL
  PER
  PERP
  MADELIN
  ARTICLE_83
  COMPANY_SHARES
  PROFESSIONAL_REAL_ESTATE
  PRECIOUS_METALS
  ART_COLLECTION
  CRYPTO
  OTHER
}

enum ActifCategory {
  IMMOBILIER
  FINANCIER
  PROFESSIONNEL
  AUTRE
}

model Actif {
  id               String         @id @default(cuid())
  cabinetId        String
  cabinet          Cabinet        @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  type             ActifType
  category         ActifCategory
  name             String
  description      String?
  value            Decimal        @db.Decimal(15, 2)
  acquisitionDate  DateTime?
  acquisitionValue Decimal?       @db.Decimal(15, 2)
  details          Json?
  annualIncome     Decimal?       @db.Decimal(12, 2)
  taxDetails       Json?
  
  // Gestion par le cabinet
  managedByFirm    Boolean        @default(false)  // Actif géré par le cabinet
  managementFees   Decimal?       @db.Decimal(5, 2) // Frais de gestion (%)
  
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  clients          ClientActif[]
  documents        ActifDocument[]
  
  @@index([cabinetId])
  @@index([type])
  @@index([category])
  @@map("actifs")
}

model ClientActif {
  id                  String  @id @default(cuid())
  clientId            String
  actifId             String
  client              Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  actif               Actif   @relation(fields: [actifId], references: [id], onDelete: Cascade)
  ownershipPercentage Decimal @db.Decimal(5, 2) @default(100.00)
  ownershipType       String?
  createdAt           DateTime @default(now())
  
  @@unique([clientId, actifId])
  @@index([clientId])
  @@index([actifId])
  @@map("client_actifs")
}

enum PassifType {
  MORTGAGE
  CONSUMER_LOAN
  PROFESSIONAL_LOAN
  REVOLVING_CREDIT
  BRIDGE_LOAN
  OTHER
}

model Passif {
  id              String      @id @default(cuid())
  cabinetId       String
  cabinet         Cabinet     @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            PassifType
  name            String
  description     String?
  initialAmount   Decimal     @db.Decimal(15, 2)
  remainingAmount Decimal     @db.Decimal(15, 2)
  interestRate    Decimal     @db.Decimal(5, 2)
  monthlyPayment  Decimal     @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime
  linkedActifId   String?
  insurance       Json?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  documents       PassifDocument[]
  
  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@map("passifs")
}

enum ContratType {
  LIFE_INSURANCE
  HEALTH_INSURANCE
  HOME_INSURANCE
  CAR_INSURANCE
  PROFESSIONAL_INSURANCE
  DEATH_INSURANCE
  DISABILITY_INSURANCE
  RETIREMENT_SAVINGS
  OTHER
}

enum ContratStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  EXPIRED
}

model Contrat {
  id              String         @id @default(cuid())
  cabinetId       String
  cabinet         Cabinet        @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            ContratType
  name            String
  provider        String
  contractNumber  String?
  startDate       DateTime
  endDate         DateTime?
  premium         Decimal?       @db.Decimal(12, 2)
  coverage        Decimal?       @db.Decimal(15, 2)
  value           Decimal?       @db.Decimal(15, 2)
  beneficiaries   Json?
  details         Json?
  commission      Decimal?       @db.Decimal(12, 2)
  nextRenewalDate DateTime?
  status          ContratStatus  @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  documents       ContratDocument[]
  
  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@index([status])
  @@map("contrats")
}

// ============================================
// MODULE 4: Documents et GED
// ============================================

enum DocumentType {
  ID_CARD
  PASSPORT
  PROOF_OF_ADDRESS
  TAX_NOTICE
  BANK_STATEMENT
  PROPERTY_DEED
  LOAN_AGREEMENT
  INSURANCE_POLICY
  INVESTMENT_STATEMENT
  ENTRY_AGREEMENT
  MISSION_LETTER
  ADEQUACY_DECLARATION
  INVESTOR_PROFILE
  ANNUAL_REPORT
  EMAIL_ATTACHMENT
  MEETING_MINUTES
  PROPOSAL
  CONTRACT
  INVOICE
  OTHER
}

enum DocumentCategory {
  IDENTITE
  FISCAL
  PATRIMOINE
  REGLEMENTAIRE
  COMMERCIAL
  AUTRE
}

enum SignatureStatus {
  PENDING
  SIGNED
  REJECTED
  EXPIRED
}

model Document {
  id                String           @id @default(cuid())
  cabinetId         String
  cabinet           Cabinet          @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  fileUrl           String
  fileSize          Int
  mimeType          String
  type              DocumentType
  category          DocumentCategory?
  tags              Json?
  version           Int              @default(1)
  parentVersion     String?
  uploadedById      String
  uploadedBy        User             @relation("UploadedBy", fields: [uploadedById], references: [id])
  uploadedAt        DateTime         @default(now())
  signatureStatus   SignatureStatus?
  signatureProvider String?
  signedAt          DateTime?
  signedBy          Json?
  isConfidential    Boolean          @default(false)
  accessLevel       String           @default("NORMAL")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  clients           ClientDocument[]
  actifs            ActifDocument[]
  passifs           PassifDocument[]
  contrats          ContratDocument[]
  projets           ProjetDocument[]
  taches            TacheDocument[]
  
  @@index([cabinetId])
  @@index([type])
  @@index([uploadedById])
  @@map("documents")
}

model ClientDocument {
  id         String   @id @default(cuid())
  clientId   String
  documentId String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([clientId, documentId])
  @@index([clientId])
  @@index([documentId])
  @@map("client_documents")
}

model ActifDocument {
  id         String   @id @default(cuid())
  actifId    String
  documentId String
  actif      Actif    @relation(fields: [actifId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([actifId, documentId])
  @@map("actif_documents")
}

model PassifDocument {
  id         String   @id @default(cuid())
  passifId   String
  documentId String
  passif     Passif   @relation(fields: [passifId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([passifId, documentId])
  @@map("passif_documents")
}

model ContratDocument {
  id         String   @id @default(cuid())
  contratId  String
  documentId String
  contrat    Contrat  @relation(fields: [contratId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([contratId, documentId])
  @@map("contrat_documents")
}

enum KYCDocumentType {
  IDENTITY
  PROOF_OF_ADDRESS
  TAX_NOTICE
  BANK_RIB
  WEALTH_JUSTIFICATION
  ORIGIN_OF_FUNDS
  OTHER
}

enum KYCDocStatus {
  PENDING
  VALIDATED
  REJECTED
  EXPIRED
}

model KYCDocument {
  id          String          @id @default(cuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        KYCDocumentType
  documentId  String?
  status      KYCDocStatus    @default(PENDING)
  validatedAt DateTime?
  validatedBy String?
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([clientId])
  @@index([status])
  @@map("kyc_documents")
}

// ============================================
// MODULE 5: Objectifs et Projets
// ============================================

enum ObjectifType {
  RETIREMENT
  REAL_ESTATE_PURCHASE
  EDUCATION
  WEALTH_TRANSMISSION
  TAX_OPTIMIZATION
  INCOME_GENERATION
  CAPITAL_PROTECTION
  OTHER
}

enum ObjectifPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ObjectifStatus {
  ACTIVE
  ACHIEVED
  CANCELLED
  ON_HOLD
}

model Objectif {
  id                  String           @id @default(cuid())
  cabinetId           String
  cabinet             Cabinet          @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type                ObjectifType
  name                String
  description         String?
  targetAmount        Decimal          @db.Decimal(15, 2)
  targetDate          DateTime
  currentAmount       Decimal?         @db.Decimal(15, 2) @default(0)
  progress            Int?             @default(0)
  priority            ObjectifPriority @default(MEDIUM)
  monthlyContribution Decimal?         @db.Decimal(12, 2)
  recommendations     Json?
  status              ObjectifStatus   @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  achievedAt          DateTime?
  
  @@index([cabinetId])
  @@index([clientId])
  @@index([type])
  @@index([status])
  @@map("objectifs")
}

enum ProjetType {
  REAL_ESTATE_PURCHASE
  BUSINESS_CREATION
  RETIREMENT_PREPARATION
  WEALTH_RESTRUCTURING
  TAX_OPTIMIZATION
  SUCCESSION_PLANNING
  OTHER
}

enum ProjetStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

model Projet {
  id              String        @id @default(cuid())
  cabinetId       String
  cabinet         Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  type            ProjetType
  estimatedBudget Decimal?      @db.Decimal(15, 2)
  actualBudget    Decimal?      @db.Decimal(15, 2)
  startDate       DateTime?
  targetDate      DateTime?
  endDate         DateTime?
  progress        Int           @default(0)
  status          ProjetStatus  @default(PLANNED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  taches          Tache[]
  documents       ProjetDocument[]
  
  @@index([cabinetId])
  @@index([clientId])
  @@index([status])
  @@map("projets")
}

model ProjetDocument {
  id         String   @id @default(cuid())
  projetId   String
  documentId String
  projet     Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([projetId, documentId])
  @@map("projet_documents")
}

// ============================================
// MODULE 6: Opportunités
// ============================================

enum OpportuniteType {
  LIFE_INSURANCE
  RETIREMENT_SAVINGS
  REAL_ESTATE_INVESTMENT
  SECURITIES_INVESTMENT
  TAX_OPTIMIZATION
  LOAN_RESTRUCTURING
  WEALTH_TRANSMISSION
  INSURANCE_REVIEW
  OTHER
}

enum OpportunitePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportuniteStatus {
  DETECTED
  QUALIFIED
  CONTACTED
  PRESENTED
  ACCEPTED
  CONVERTED
  REJECTED
  LOST
}

model Opportunite {
  id                  String              @id @default(cuid())
  cabinetId           String
  cabinet             Cabinet             @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  conseillerId        String
  conseiller          User                @relation(fields: [conseillerId], references: [id])
  clientId            String
  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type                OpportuniteType
  name                String
  description         String?
  estimatedValue      Decimal?            @db.Decimal(15, 2)
  score               Int?                @default(0)
  confidence          Decimal?            @db.Decimal(5, 2)
  priority            OpportunitePriority @default(MEDIUM)
  status              OpportuniteStatus   @default(DETECTED)
  stage               String?
  detectedAt          DateTime            @default(now())
  qualifiedAt         DateTime?
  contactedAt         DateTime?
  presentedAt         DateTime?
  acceptedAt          DateTime?
  convertedAt         DateTime?
  rejectedAt          DateTime?
  actionDeadline      DateTime?
  rejectionReason     String?
