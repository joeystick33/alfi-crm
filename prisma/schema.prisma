  @@index([cabinetId])
  @@index([conseillerId])
  @@index([clientId])
  @@index([status])
  @@index([type])
  // NOUVEAUX INDEX COMPOSITES
  @@index([cabinetId, conseillerId, status])
  @@index([cabinetId, clientId, status])
  @@index([cabinetId, status, priority])
  @@index([actionDeadline, status])
