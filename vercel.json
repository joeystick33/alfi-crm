{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/patrimoine-snapshot",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/kyc-expiration",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/cleanup-audit-logs",
      "schedule": "0 4 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "app/api/cron/**/*.ts": {
      "maxDuration": 300
    }
  }
}
