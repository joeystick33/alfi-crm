# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aura_crm"
DIRECT_URL="postgresql://user:password@localhost:5432/aura_crm"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Gmail OAuth
GMAIL_CLIENT_ID="your-gmail-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/api/email/gmail/callback"

# Microsoft OAuth (Outlook Calendar & Mail)
# Créer une app sur https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
# Redirect URIs à configurer dans Azure AD:
# - http://localhost:3000/api/auth/outlook/callback (dev)
# - https://your-domain.com/api/auth/outlook/callback (prod)

# ============================================
# BACKENDS JAVA SIMULATEURS PATRIMONIAUX
# ============================================

# Backend Patrimonial Spring (port 8081)
JAVA_PATRIMOINE_URL="http://localhost:8081"

# Backend Assurance-Vie (port 8080)
JAVA_ASSURANCE_VIE_URL="http://localhost:8080"

# Backend PER Salariés (port 8082)
JAVA_PER_SALARIES_URL="http://localhost:8082"

# Backend Investissement Immobilier (port 8083)
JAVA_IMMOBILIER_URL="http://localhost:8083"

# Backend Prévoyance TNS (port 8084)
JAVA_PREVOYANCE_TNS_URL="http://localhost:8084"

# ============================================
# BACKENDS NODE.JS SIMULATEURS
# ============================================

# Backend Capacité d'Emprunt (port 3001)
NODE_CAPACITE_EMPRUNT_URL="http://localhost:3001"

# Backend Mensualité Crédit (port 3002)
NODE_MENSUALITE_URL="http://localhost:3002"

# Backend Enveloppe Fiscale TNS (port 3003)
NODE_ENVELOPPE_FISCALE_URL="http://localhost:3003"

# Backend PER TNS (port 3004)
NODE_PER_TNS_URL="http://localhost:3004"

# Backend PTZ 2025 (port 3005)
NODE_PTZ_URL="http://localhost:3005"

# Backend Épargne Flexible (port 3006)
NODE_EPARGNE_URL="http://localhost:3006"

# ============================================
# API DONNÉES ENTREPRISES
# ============================================

# L'API recherche-entreprises.api.gouv.fr est utilisée par défaut
# Elle est GRATUITE et ne nécessite AUCUNE configuration

# API RNE INPI (OPTIONNEL) - Pour les comptes annuels détaillés
# Sans cette config, le service fonctionne mais sans les bilans financiers
# Créer un compte gratuit sur https://data.inpi.fr/
# Puis aller dans "Mes accès API / SFTP" pour activer l'accès
INPI_USERNAME="your-inpi-username"
INPI_PASSWORD="your-inpi-password"

# ============================================
# REDIS & BULLMQ
# ============================================

# Redis connection URL (requis pour BullMQ et cache)
# Local: redis://localhost:6379
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
# Redis Cloud: redis://default:xxx@xxx.redislabs.com:6379
REDIS_URL="redis://localhost:6379"

# OU configuration séparée (optionnel, si REDIS_URL non défini)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ============================================
# SÉCURITÉ — Chiffrement des secrets en BDD
# ============================================

# Clé de chiffrement AES-256 pour les tokens OAuth, clés API tierces, secrets webhook
# OBLIGATOIRE en production. Générer avec : openssl rand -hex 32
ENCRYPTION_SECRET="your-encryption-secret-min-32-chars-here"

# ============================================
# CRON JOBS
# ============================================

# Secret pour authentifier les appels CRON (générer avec: openssl rand -hex 32)
CRON_SECRET="your-cron-secret-here"

# ============================================
# INTELLIGENCE ARTIFICIELLE — Narratifs enrichis
# ============================================
#
# Le système détecte automatiquement le backend IA dans cet ordre :
#   1. Ollama (local, gratuit, AUCUNE CLÉ requise)
#   2. Mistral Cloud API (optionnel, avec clé)
#   3. Fallback statique (narratifs du moteur d'audit)
#
# ── OPTION 1 : Ollama (recommandé, 100% gratuit) ──
# Installation macOS :
#   brew install ollama
#   ollama pull mistral        ← télécharge le modèle (~4 Go)
#   ollama serve               ← lance le serveur local
# C'est tout ! Aucune clé nécessaire.
#
# Variables optionnelles (valeurs par défaut suffisantes) :
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="mistral"
#
# ── OPTION 2 : Mistral Cloud API (optionnel) ──
# Si Ollama n'est pas installé, vous pouvez utiliser l'API cloud :
# Créer un compte : https://console.mistral.ai/
# Clé gratuite avec quota limité
MISTRAL_API_KEY=""

# ============================================
# AURA — Agent IA Autonome (Architecture Multi-Modèle)
# ============================================
#
# AURA utilise une architecture dual-model :
#   • Orchestrator (GPT-4o-mini) — planification, synthèse, gouvernance
#   • Subagent (Mistral Small)   — CRUD CRM, extraction, copilote live
#   • STT (Whisper/Groq)         — transcription streaming
#
# Fallback automatique : OpenAI → Mistral → Ollama
# Si aucune clé n'est configurée, Ollama local est utilisé.
#
# ── Orchestrator (OpenAI) ──
# Créer un compte : https://platform.openai.com/
OPENAI_API_KEY=""
# AURA_ORCHESTRATOR_MODEL="gpt-4o-mini"   # Modèle orchestrateur (défaut: gpt-4o-mini)
#
# ── Subagent (Mistral) ──
# Utilise MISTRAL_API_KEY défini ci-dessus
# AURA_SUBAGENT_MODEL="mistral-small-latest"  # Modèle subagent (défaut: mistral-small-latest)
#
# ── STT (Groq — transcription ultra-rapide) ──
# Créer un compte : https://console.groq.com/
GROQ_API_KEY=""
# AURA_STT_MODEL="whisper-large-v3-turbo"  # Modèle STT (défaut: whisper-large-v3-turbo)

# ============================================
# RECHERCHE WEB (Agent IA)
# ============================================
#
# L'agent AURA peut rechercher sur le web pour des informations actualisées
# (réglementation, fiscalité, taux, marchés). Configurez au moins un provider :
#
# ── Tavily (recommandé pour agents IA) ──
# Créer un compte : https://tavily.com/ (1000 recherches/mois gratuites)
TAVILY_API_KEY=""
#
# ── Serper.dev (fallback, Google Search) ──
# Créer un compte : https://serper.dev/ (2500 recherches gratuites)
SERPER_API_KEY=""
#
# ── DeepSeek (provider IA ultra-économique) ──
DEEPSEEK_API_KEY=""
#
# ── Google AI (Gemini) ──
GOOGLE_AI_API_KEY=""
#
# ── Anthropic ──
ANTHROPIC_API_KEY=""

# ============================================
# EMAIL PROVIDER
# ============================================

# Provider d'email: resend, sendgrid, smtp, console (dev)
EMAIL_PROVIDER="console"

# Email expéditeur par défaut
EMAIL_FROM="Aura CRM <noreply@aura-crm.com>"

# Resend (recommandé)
RESEND_API_KEY="re_xxx"

# SendGrid (alternatif)
SENDGRID_API_KEY="SG.xxx"

# SMTP (custom)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user"
SMTP_PASS="password"
