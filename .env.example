# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aura_crm"
DIRECT_URL="postgresql://user:password@localhost:5432/aura_crm"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Gmail OAuth
GMAIL_CLIENT_ID="your-gmail-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/api/email/gmail/callback"

# Microsoft OAuth (Outlook Calendar & Mail)
# Créer une app sur https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
# Redirect URIs à configurer dans Azure AD:
# - http://localhost:3000/api/auth/outlook/callback (dev)
# - https://your-domain.com/api/auth/outlook/callback (prod)

# ============================================
# BACKENDS JAVA SIMULATEURS PATRIMONIAUX
# ============================================

# Backend Patrimonial Spring (port 8081)
JAVA_PATRIMOINE_URL="http://localhost:8081"

# Backend Assurance-Vie (port 8080)
JAVA_ASSURANCE_VIE_URL="http://localhost:8080"

# Backend PER Salariés (port 8082)
JAVA_PER_SALARIES_URL="http://localhost:8082"

# Backend Investissement Immobilier (port 8083)
JAVA_IMMOBILIER_URL="http://localhost:8083"

# Backend Prévoyance TNS (port 8084)
JAVA_PREVOYANCE_TNS_URL="http://localhost:8084"

# ============================================
# BACKENDS NODE.JS SIMULATEURS
# ============================================

# Backend Capacité d'Emprunt (port 3001)
NODE_CAPACITE_EMPRUNT_URL="http://localhost:3001"

# Backend Mensualité Crédit (port 3002)
NODE_MENSUALITE_URL="http://localhost:3002"

# Backend Enveloppe Fiscale TNS (port 3003)
NODE_ENVELOPPE_FISCALE_URL="http://localhost:3003"

# Backend PER TNS (port 3004)
NODE_PER_TNS_URL="http://localhost:3004"

# Backend PTZ 2025 (port 3005)
NODE_PTZ_URL="http://localhost:3005"

# Backend Épargne Flexible (port 3006)
NODE_EPARGNE_URL="http://localhost:3006"

# ============================================
# API DONNÉES ENTREPRISES
# ============================================

# L'API recherche-entreprises.api.gouv.fr est utilisée par défaut
# Elle est GRATUITE et ne nécessite AUCUNE configuration

# API RNE INPI (OPTIONNEL) - Pour les comptes annuels détaillés
# Sans cette config, le service fonctionne mais sans les bilans financiers
# Créer un compte gratuit sur https://data.inpi.fr/
# Puis aller dans "Mes accès API / SFTP" pour activer l'accès
INPI_USERNAME="your-inpi-username"
INPI_PASSWORD="your-inpi-password"

# ============================================
# REDIS & BULLMQ
# ============================================

# Redis connection URL (requis pour BullMQ et cache)
# Local: redis://localhost:6379
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
# Redis Cloud: redis://default:xxx@xxx.redislabs.com:6379
REDIS_URL="redis://localhost:6379"

# OU configuration séparée (optionnel, si REDIS_URL non défini)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ============================================
# CRON JOBS
# ============================================

# Secret pour authentifier les appels CRON (générer avec: openssl rand -hex 32)
CRON_SECRET="your-cron-secret-here"

# ============================================
# EMAIL PROVIDER
# ============================================

# Provider d'email: resend, sendgrid, smtp, console (dev)
EMAIL_PROVIDER="console"

# Email expéditeur par défaut
EMAIL_FROM="Aura CRM <noreply@aura-crm.com>"

# Resend (recommandé)
RESEND_API_KEY="re_xxx"

# SendGrid (alternatif)
SENDGRID_API_KEY="SG.xxx"

# SMTP (custom)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user"
SMTP_PASS="password"
